---
import { navigation, siteConfig, services } from '../../data/site';
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';
---

<style>
  .dark-logo { display: block !important; }
  .light-logo { display: none !important; }
  :global(.light) .dark-logo { display: none !important; }
  :global(.light) .light-logo { display: block !important; }
</style>

<footer class="border-t border-[var(--border)] bg-[var(--bg)]">
  <!-- Main Footer -->
  <div class="container py-20">
    <!-- Top: CTA Row -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 py-16 border-b border-[var(--border)]">
      <div>
        <h3 class="text-2xl md:text-3xl font-semibold text-[var(--text)] mb-4 tracking-tight">Let's talk</h3>
        <p class="text-[var(--text-secondary)]">Ready to get started? We'd love to hear from you.</p>
      </div>
      <div class="flex items-center gap-4">
        <Button href="/contact" size="md">
          Contact
          <Icon name="arrow-right" size={16} />
        </Button>
      </div>
    </div>

    <!-- Link Columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 py-16">
      <!-- Services -->
      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase text-[var(--text)] mb-6">Services</h4>
        <ul class="space-y-4">
          {services.slice(0, 5).map((service) => (
            <li>
              <a
                href={`/services/${service.slug}`}
                class="text-sm text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors duration-300"
              >
                {service.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase text-[var(--text)] mb-6">Company</h4>
        <ul class="space-y-4">
          {navigation.filter(item => !item.children).map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors duration-300"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase text-[var(--text)] mb-6">Get in touch</h4>
        <ul class="space-y-4">
          <li>
            <a
              href={`tel:${siteConfig.phone.replace(/[^0-9]/g, '')}`}
              class="text-sm text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors duration-300"
            >
              {siteConfig.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${siteConfig.email}`}
              class="text-sm text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors duration-300"
            >
              {siteConfig.email}
            </a>
          </li>
          {siteConfig.address && (
            <li class="text-sm text-[var(--text-secondary)]">
              {siteConfig.address}
            </li>
          )}
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase text-[var(--text)] mb-6">Social</h4>
        <ul class="space-y-4">
          {siteConfig.socials.map((social) => (
            <li>
              <a
                href={social.url}
                class="inline-flex items-center gap-2 text-sm text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors duration-300"
                aria-label={social.platform}
              >
                <Icon name={social.icon} size={14} />
                {social.platform}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-[var(--border)] py-5">
    <div class="container py-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <a href="/" class="flex items-center gap-2">
            <img 
              src="https://res.cloudinary.com/ds85pv6ht/image/upload/v1770167617/logo-white_hz0s9s.png" 
              alt="SoCal Web Experts" 
              class="dark-logo"
              style="height: 36px; width: auto;"
            />
            <img 
              src="https://res.cloudinary.com/ds85pv6ht/image/upload/v1770167617/logo-black_t3ushq.png" 
              alt="SoCal Web Experts" 
              class="light-logo"
              style="height: 36px; width: auto;"
            />
          </a>
          <span class="text-xs text-[var(--text-secondary)]">© {new Date().getFullYear()} {siteConfig.name}</span>
        </div>
        <div class="flex items-center gap-6 text-xs text-[var(--text-secondary)]">
          <span class="flex items-center gap-1.5">
            <span class="text-sm">🇺🇸</span>
            Proudly Made in USA
          </span>
          <a href="/privacy" class="hover:text-[var(--text)] transition-colors duration-300">Privacy</a>
          <a href="/terms" class="hover:text-[var(--text)] transition-colors duration-300">Terms</a>
        </div>
      </div>
    </div>
  </div>
</footer>
