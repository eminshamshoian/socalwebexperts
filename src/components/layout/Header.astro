---
import { navigation, siteConfig } from '../../data/site';
import Button from '../ui/Button.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';
import Icon from '../ui/Icon.astro';
---

<header class="fixed z-50 w-full px-2" id="header">
  <nav class="group" data-scrolled="false">
    <!-- Inner container: full-width → shrinks to pill on scroll -->
    <div
      id="nav-inner"
      class="mx-auto mt-2 max-w-6xl px-6 transition-all duration-300 lg:px-12"
    >
      <div class="relative flex flex-wrap items-center justify-between gap-6 pt-3 pb-6 lg:gap-0 lg:py-4">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group/logo z-10">
          <img
            src="https://res.cloudinary.com/ds85pv6ht/image/upload/v1770167617/logo-white_hz0s9s.png"
            alt="SoCal Web Experts"
            class="dark-logo"
            style="height: 50px; width: auto; max-width: 100px;"
          />
          <img
            src="https://res.cloudinary.com/ds85pv6ht/image/upload/v1770167617/logo-black_t3ushq.png"
            alt="SoCal Web Experts"
            class="light-logo"
            style="height: 50px; width: auto; max-width: 100px;"
          />
        </a>

        <!-- Desktop Navigation -->
        <div class="absolute inset-0 m-auto hidden size-fit lg:block">
          <ul class="flex gap-1 text-sm">
            {navigation.map((item) => (
              item.children ? (
                <li class="relative group/dd">
                  <button class="flex items-center gap-1.5 px-4 py-2 text-[13px] tracking-wide uppercase font-medium text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors duration-300">
                    {item.label}
                    <Icon name="chevron-down" size={12} class="transition-transform duration-300 group-hover/dd:rotate-180" />
                  </button>
                  <div class="absolute top-full left-0 pt-3 opacity-0 invisible group-hover/dd:opacity-100 group-hover/dd:visible transition-all duration-300 translate-y-1 group-hover/dd:translate-y-0">
                    <div class="bg-[var(--bg)] border border-[var(--border)] rounded-2xl shadow-2xl shadow-black/20 py-2 min-w-[200px] backdrop-blur-xl">
                      {item.children.map((child) => (
                        <a
                          href={child.href}
                          class="block px-4 py-2.5 text-sm text-[var(--text-secondary)] hover:text-primary-500 hover:bg-[var(--bg-secondary)] transition-all duration-200"
                        >
                          {child.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </li>
              ) : (
                <li>
                  <a
                    href={item.href}
                    class="block px-4 py-2 text-[13px] tracking-wide uppercase font-medium text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors duration-300"
                  >
                    {item.label}
                  </a>
                </li>
              )
            ))}
          </ul>
        </div>

        <!-- Right Side -->
        <div class="flex items-center gap-2">
          <ThemeToggle class="hidden sm:flex" />

          <a
            href="/contact"
            id="header-cta"
            class="text-sm font-medium px-5 py-2.5 rounded-md bg-primary-500 text-white transition-all duration-150 shadow-[3px_3px_0px_0px_#3F6212] hover:shadow-[1px_1px_0px_0px_#3F6212] hover:translate-x-[2px] hover:translate-y-[2px]"
          >
            Get Started
          </a>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            class="lg:hidden p-2.5 rounded-xl text-[var(--text)] hover:bg-[var(--bg-secondary)] transition-colors z-10"
            aria-label="Toggle menu"
          >
            <Icon name="menu" size={22} class="menu-icon" />
            <Icon name="close" size={22} class="close-icon hidden" />
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu – Full Screen -->
  <div id="mobile-menu" class="lg:hidden fixed inset-0 bg-[var(--bg)] z-40 hidden opacity-0 transition-opacity duration-300">
    <div class="flex flex-col h-full py-24 px-8 overflow-y-auto">
      <!-- Close Button -->
      <button
        id="mobile-menu-close"
        class="absolute top-5 right-5 p-2.5 rounded-xl text-[var(--text)] hover:bg-[var(--bg-secondary)] transition-colors z-50"
        aria-label="Close menu"
      >
        <Icon name="close" size={24} />
      </button>

      <!-- Navigation -->
      <nav class="flex-1 flex flex-col justify-center -mt-16">
        {navigation.map((item, idx) => (
          item.children ? (
            <div class="mb-4 mobile-nav-item">
              <button
                class="mobile-nav-link mobile-dropdown-trigger w-full flex items-center justify-between py-4 text-3xl font-bold text-[var(--text)] hover:text-primary-500 transition-colors"
                data-dropdown={`dropdown-${idx}`}
                style={`animation-delay: ${idx * 60}ms`}
              >
                <span>{item.label}</span>
                <Icon name="chevron-down" size={20} class="dropdown-icon transition-transform duration-300" />
              </button>
              <div
                class="mobile-dropdown-content hidden pl-4 space-y-1"
                id={`dropdown-${idx}`}
              >
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block py-2.5 text-lg font-medium text-[var(--text-secondary)] hover:text-primary-500 transition-colors"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="mobile-nav-link block py-4 text-4xl font-bold text-[var(--text)] hover:text-primary-500 transition-colors"
              style={`animation-delay: ${idx * 60}ms`}
            >
              {item.label}
            </a>
          )
        ))}
      </nav>

      <!-- Bottom Section -->
      <div class="border-t border-[var(--border)] py-8 space-y-5">
        <div class="flex items-center justify-between">
          <span class="text-sm text-[var(--text-secondary)]">Theme</span>
          <ThemeToggle />
        </div>
        <a
          href={`tel:${siteConfig.phone.replace(/[^0-9]/g, '')}`}
          class="flex items-center gap-2 text-[var(--text)]"
        >
          <Icon name="phone" size={16} class="text-primary-500" />
          <span class="text-sm">{siteConfig.phone}</span>
        </a>
        <Button href="/contact" fullWidth size="lg">
          Get Started
        </Button>
      </div>
    </div>
  </div>
</header>

<!-- Spacer so content doesn't hide behind fixed header -->
<div class="h-20 md:h-20"></div>

<style>
  /* Pill nav on scroll */
  #nav-inner.scrolled {
    max-width: 56rem; /* ~max-w-4xl equivalent */
    border-radius: 1rem;
    border: 1px solid var(--border);
    background: rgba(var(--bg-rgb, 10, 10, 10), 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }

  /* Mobile menu open state */
  #mobile-menu.open {
    opacity: 1;
  }

  .mobile-nav-link {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease, transform 0.4s ease, color 0.2s ease;
  }

  #mobile-menu.open .mobile-nav-link {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-dropdown-content {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.3s ease, opacity 0.2s ease, padding 0.3s ease;
    padding-top: 0;
    padding-bottom: 0;
  }

  .mobile-dropdown-content.open {
    max-height: 500px;
    opacity: 1;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .mobile-dropdown-trigger.active .dropdown-icon {
    transform: rotate(180deg);
  }
</style>

<style>
  .dark-logo { display: block !important; }
  .light-logo { display: none !important; }
  :global(.light) .dark-logo { display: none !important; }
  :global(.light) .light-logo { display: block !important; }

  /* Light mode pill bg */
  :global(.light) #nav-inner.scrolled {
    background: rgba(250, 250, 250, 0.75);
  }
</style>

<script>
  function closeMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    const menuIcon = document.querySelector('.menu-icon');
    const closeIcon = document.querySelector('.close-icon');
    const body = document.body;

    if (menu) {
      menu.classList.remove('open');
      setTimeout(() => { menu.classList.add('hidden'); }, 300);
      if (menuIcon) menuIcon.classList.remove('hidden');
      if (closeIcon) closeIcon.classList.add('hidden');
      body.style.overflow = '';
    }
  }

  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = btn?.querySelector('.menu-icon');
    const closeIcon = btn?.querySelector('.close-icon');
    const body = document.body;

    if (btn && menu && menuIcon && closeIcon) {
      btn.addEventListener('click', () => {
        const isHidden = menu.classList.contains('hidden');
        if (isHidden) {
          menu.classList.remove('hidden');
          requestAnimationFrame(() => { menu.classList.add('open'); });
          menuIcon.classList.add('hidden');
          closeIcon.classList.remove('hidden');
          body.style.overflow = 'hidden';
        } else {
          closeMobileMenu();
        }
      });
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', () => { closeMobileMenu(); });
    }

    if (menu) {
      menu.querySelectorAll('a.mobile-nav-link, .mobile-dropdown-content a').forEach(link => {
        link.addEventListener('click', () => { closeMobileMenu(); });
      });
    }

    const dropdownTriggers = document.querySelectorAll('.mobile-dropdown-trigger');
    dropdownTriggers.forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const dropdownId = trigger.getAttribute('data-dropdown');
        const dropdown = dropdownId ? document.getElementById(dropdownId) : null;

        if (dropdown) {
          const isOpen = dropdown.classList.contains('open');
          document.querySelectorAll('.mobile-dropdown-content').forEach(dd => {
            if (dd !== dropdown) { dd.classList.remove('open'); dd.classList.add('hidden'); }
          });
          document.querySelectorAll('.mobile-dropdown-trigger').forEach(tr => {
            if (tr !== trigger) { tr.classList.remove('active'); }
          });

          if (isOpen) {
            dropdown.classList.remove('open');
            dropdown.classList.add('hidden');
            trigger.classList.remove('active');
          } else {
            dropdown.classList.remove('hidden');
            requestAnimationFrame(() => { dropdown.classList.add('open'); });
            trigger.classList.add('active');
          }
        }
      });
    });
  }

  function initHeaderScroll() {
    const navInner = document.getElementById('nav-inner');
    if (!navInner) return;

    const onScroll = () => {
      navInner.classList.toggle('scrolled', window.scrollY > 50);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  initMobileMenu();
  initHeaderScroll();

  document.addEventListener('astro:after-swap', () => {
    initMobileMenu();
    initHeaderScroll();
  });
</script>
