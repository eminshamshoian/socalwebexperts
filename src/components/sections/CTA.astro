---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { siteConfig } from '../../data/site';
---

<section class="py-24 md:py-32 bg-[var(--bg-secondary)]">
  <div class="container">
    <div class="w-full max-w-4xl mx-auto flex flex-col items-center text-center fade-in">
      <!-- Large editorial headline -->
      <h2 class="text-[var(--text)] mb-8">
        Ready to stop losing<br/>customers online?
      </h2>

      <p class="type-lead w-full max-w-2xl mx-auto my-8">
        Let's build a fast, trustworthy website that ranks better and converts more leads.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 py-8">
        <Button href="/contact" size="lg">
          Book a Free Strategy Call
          <Icon name="arrow-right" size={18} />
        </Button>
        <a 
          href={`tel:${siteConfig.phone.replace(/[^0-9]/g, '')}`}
          class="inline-flex items-center gap-2 text-lg text-[var(--text)] font-medium hover:text-primary-500 transition-colors duration-300"
        >
          <Icon name="phone" size={18} />
          {siteConfig.phone}
        </a>
      </div>

      <p class="type-caption my-8">No pressure. Just a plan.</p>
    </div>
  </div>
</section>
