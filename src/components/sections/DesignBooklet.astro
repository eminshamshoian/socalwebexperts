---
import { portfolioItems } from '../../data/site';

const showcaseItems = portfolioItems.slice(0, 5);
---

<section class="showcase-section relative overflow-hidden pb-12 pt-0 md:pb-14 md:pt-0" aria-label="Portfolio design preview showcase">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="showcase-glow showcase-glow--left"></div>
    <div class="showcase-glow showcase-glow--right"></div>
    <svg class="showcase-squiggle" viewBox="0 0 120 140" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M72 4C76 31 39 35 39 57C39 81 7 82 7 111" stroke="currentColor" stroke-width="8" stroke-linecap="round"/>
      <path d="M105 22C105 51 72 54 72 80C72 104 43 105 43 132" stroke="currentColor" stroke-width="8" stroke-linecap="round"/>
    </svg>
    <div class="showcase-star"></div>
    <div class="showcase-blob"></div>
  </div>

  <div class="mx-auto w-full max-w-[1200px] px-6">
    <a href="/portfolio" class="showcase-fan fade-in" aria-label="View portfolio projects">
      {showcaseItems.map((item, index) => (
        <div class={`showcase-card showcase-card--${index + 1}`} aria-hidden="true">
          <img src={item.image} alt="" loading="lazy" />
        </div>
      ))}
    </a>
  </div>
</section>

<style>
  .showcase-section {
    margin-top: clamp(-5rem, -6vw, -2.25rem);
    background: var(--bg);
  }

  .showcase-fan {
    position: relative;
    isolation: isolate;
    display: block;
    min-height: clamp(20rem, 40vw, 32rem);
    color: inherit;
    text-decoration: none;
  }

  .showcase-card {
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(8.75rem, 18vw, 15.5rem);
    aspect-ratio: 0.72;
    overflow: hidden;
    border: 4px solid color-mix(in srgb, var(--text) 84%, transparent);
    border-radius: clamp(0.75rem, 1.6vw, 1.15rem);
    background: #050505;
    box-shadow: 0 2rem 4.5rem rgba(0, 0, 0, 0.5);
    transition: transform 0.45s ease, border-color 0.45s ease, box-shadow 0.45s ease;
  }

  .showcase-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .showcase-card--1 {
    z-index: 1;
    transform: translate(-158%, -43%) rotate(-18deg);
  }

  .showcase-card--2 {
    z-index: 2;
    transform: translate(-105%, -49%) rotate(-10deg);
  }

  .showcase-card--3 {
    z-index: 5;
    width: clamp(11rem, 23vw, 19.5rem);
    transform: translate(-50%, -55%) rotate(0deg);
    border-width: 5px;
  }

  .showcase-card--4 {
    z-index: 3;
    transform: translate(8%, -49%) rotate(10deg);
  }

  .showcase-card--5 {
    z-index: 1;
    transform: translate(58%, -43%) rotate(18deg);
  }

  .showcase-fan:hover .showcase-card {
    border-color: color-mix(in srgb, var(--text) 96%, transparent);
    box-shadow: 0 2.5rem 5rem rgba(0, 0, 0, 0.58);
  }

  .showcase-fan:hover .showcase-card--1 {
    transform: translate(-168%, -45%) rotate(-22deg);
  }

  .showcase-fan:hover .showcase-card--2 {
    transform: translate(-112%, -51%) rotate(-13deg);
  }

  .showcase-fan:hover .showcase-card--3 {
    transform: translate(-50%, -59%) rotate(0deg) scale(1.025);
  }

  .showcase-fan:hover .showcase-card--4 {
    transform: translate(14%, -51%) rotate(13deg);
  }

  .showcase-fan:hover .showcase-card--5 {
    transform: translate(68%, -45%) rotate(22deg);
  }

  .showcase-glow {
    position: absolute;
    width: 18rem;
    height: 18rem;
    border-radius: 999px;
    filter: blur(5rem);
    opacity: 0.45;
  }

  .showcase-glow--left {
    left: 8%;
    top: 18%;
    background: rgba(99, 102, 241, 0.25);
  }

  .showcase-glow--right {
    right: 8%;
    bottom: 12%;
    background: rgba(163, 230, 53, 0.2);
  }

  .showcase-squiggle {
    position: absolute;
    left: clamp(1rem, 8vw, 9rem);
    top: 23%;
    width: clamp(4rem, 9vw, 7rem);
    color: rgba(250, 250, 250, 0.8);
  }

  .showcase-star {
    position: absolute;
    right: clamp(2rem, 9vw, 11rem);
    bottom: 22%;
    width: clamp(4.5rem, 10vw, 8rem);
    aspect-ratio: 1;
    background: #d9f99d;
    clip-path: polygon(50% 0%, 61% 36%, 100% 50%, 61% 64%, 50% 100%, 39% 64%, 0% 50%, 39% 36%);
    transform: rotate(14deg);
  }

  .showcase-blob {
    position: absolute;
    right: clamp(0.5rem, 4vw, 5rem);
    top: 27%;
    width: clamp(4.5rem, 10vw, 8rem);
    aspect-ratio: 1;
    border-radius: 55% 45% 55% 45%;
    background: rgba(163, 230, 53, 0.16);
    transform: rotate(-24deg);
  }

  @media (max-width: 767px) {
    .showcase-section {
      margin-top: -3.5rem;
      padding-top: 0;
      padding-bottom: 2.5rem;
    }

    .showcase-fan {
      min-height: 20rem;
    }

    .showcase-card {
      width: clamp(8rem, 35vw, 11rem);
      border-width: 3px;
    }

    .showcase-card--3 {
      width: clamp(10rem, 45vw, 14rem);
      border-width: 4px;
    }

    .showcase-squiggle {
      left: 0.75rem;
      top: 12%;
      opacity: 0.55;
    }

    .showcase-star {
      right: 1rem;
      bottom: 12%;
      opacity: 0.9;
    }

    .showcase-blob {
      display: none;
    }
  }
</style>
