---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { stats } from '../../data/site';
---

<section class="relative min-h-[calc(100vh-4rem)] md:min-h-[calc(100vh-5rem)] flex items-center overflow-hidden">
  <!-- Subtle Background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 right-0 w-[600px] h-[400px] bg-primary-500/8 rounded-full blur-[100px]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_50%,transparent_0%,var(--bg)_70%)]"></div>
  </div>

  <div class="container py-16 md:py-24 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-24 xl:gap-32 items-center">
      <!-- Left Content -->
      <div class="max-w-xl">
        <!-- Small intro text -->
        <p class="text-primary-500 text-sm font-medium tracking-wide uppercase mb-6 fade-in py-10">
          Web Design & Digital Marketing
        </p>

        <!-- Main Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-bold text-[var(--text)] mb-6 leading-[1.1] fade-in" style="animation-delay: 0.05s;">
          We build websites that
          <span class="text-primary-500">actually work</span>
          for your business
        </h1>

        <!-- Subheadline -->
        <p class="text-lg text-[var(--text-secondary)] mb-10 leading-relaxed fade-in" style="animation-delay: 0.1s;">
          Custom websites, SEO, and marketing for local businesses. No templates. No page builders. Just clean code and real results.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-4 mb-10 fade-in py-5" style="animation-delay: 0.15s;">
          <Button href="/contact" size="lg">
            Start Your Project
          </Button>
          <Button href="/portfolio" variant="ghost" size="lg">
            See Our Work
            <Icon name="arrow-right" size={18} />
          </Button>
        </div>

        <!-- Simple trust indicators -->
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-[var(--text-secondary)] fade-in" style="animation-delay: 0.2s;">
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
            30-day delivery
          </span>
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
            No contracts
          </span>
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
            Unlimited revisions
          </span>
        </div>
      </div>

      <!-- Right - Browser Mockup -->
      <div class="relative fade-in lg:fade-in" style="animation-delay: 0.25s;">
        <!-- Glow effect behind -->
        <div class="absolute -inset-4 bg-gradient-to-br from-primary-500/20 via-primary-500/5 to-transparent rounded-3xl blur-2xl"></div>
        
        <!-- Browser Window -->
        <div class="relative bg-[var(--bg-secondary)] rounded-xl border border-[var(--border)] shadow-2xl shadow-black/20 overflow-hidden">
          <!-- Browser Header -->
          <div class="flex items-center gap-2 px-4 py-3 bg-[var(--bg-tertiary)] border-b border-[var(--border)]">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-[#FF5F57]"></div>
              <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
              <div class="w-3 h-3 rounded-full bg-[#28CA41]"></div>
            </div>
            <div class="flex-1 mx-3">
              <div class="flex items-center gap-2 bg-[var(--bg)] rounded-md px-3 py-1.5 text-xs text-[var(--text-secondary)]">
                <svg class="w-3 h-3 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                </svg>
                <span>theautoguys.com</span>
              </div>
            </div>
          </div>
          
          <!-- Screenshot -->
          <div class="bg-[var(--bg)]">
            <img 
              src="https://res.cloudinary.com/ds85pv6ht/image/upload/v1770167617/hero-mockup_tqloss.png" 
              alt="Example website design by SoCal Web Experts - The Auto Guys car dealership website with modern design and conversion-focused layout" 
              class="w-full h-auto block"
              loading="eager"
            />
          </div>
        </div>

        <!-- Floating badge -->
        <div class="absolute -bottom-3 -left-3 md:-bottom-4 md:-left-4 bg-[var(--bg)] border border-[var(--border)] rounded-lg px-3 py-2 shadow-lg flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-green-500/20 flex items-center justify-center">
            <Icon name="trending-up" size={16} class="text-green-500" />
          </div>
          <div>
            <div class="text-xs text-[var(--text-secondary)]">Conversions</div>
            <div class="text-sm font-semibold text-[var(--text)]">+127%</div>
          </div>
        </div>

        <!-- Floating badge top right -->
        <a 
          href="https://www.autoguysla.com/" 
          target="_blank" 
          rel="noopener noreferrer"
          class="absolute -top-2 -right-2 md:-top-3 md:-right-3 bg-primary-500 hover:bg-primary-600 text-white rounded-lg px-3 py-1.5 shadow-lg text-xs font-medium transition-colors"
        >
          Live Project ↗
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="mt-20 pt-12 border-t border-[var(--border)]">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
        {stats.map((stat, index) => (
          <div class="fade-in" style={`animation-delay: ${0.3 + index * 0.05}s`}>
            <div class="text-3xl md:text-4xl font-bold text-[var(--text)] mb-1">
              {stat.value}<span class="text-primary-500">{stat.suffix}</span>
            </div>
            <div class="text-sm text-[var(--text-secondary)]">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
