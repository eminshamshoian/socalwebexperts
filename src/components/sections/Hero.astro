---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import DesignBooklet from './DesignBooklet.astro';
---

<section
  class="hero-section relative flex flex-col overflow-hidden bg-[var(--bg)] pt-12 pb-0 md:min-h-[min(100dvh,960px)] md:py-24 lg:py-32 xl:py-36"
>
  <!-- Glowing arcs: indigo/violet complements lime primary -->
  <div class="hero-glow pointer-events-none absolute inset-0" aria-hidden="true">
    <svg
      class="hero-glow-svg hero-glow-svg--a"
      viewBox="0 0 600 600"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <linearGradient id="hero-arc-grad-a" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color: rgb(165 180 252); stop-opacity: 0.45" />
          <stop offset="45%" style="stop-color: rgb(129 140 248); stop-opacity: 0.3" />
          <stop offset="100%" style="stop-color: rgb(79 70 229); stop-opacity: 0.18" />
        </linearGradient>
        <filter id="hero-glow-blur-a" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="14" result="b" />
          <feMerge>
            <feMergeNode in="b" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>
      <circle
        cx="300"
        cy="300"
        r="260"
        stroke="url(#hero-arc-grad-a)"
        stroke-width="36"
        opacity="0.5"
        filter="url(#hero-glow-blur-a)"
      />
      <circle cx="300" cy="300" r="260" stroke="url(#hero-arc-grad-a)" stroke-width="10" opacity="0.22" />
    </svg>
    <svg
      class="hero-glow-svg hero-glow-svg--b"
      viewBox="0 0 500 500"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <linearGradient id="hero-arc-grad-b" x1="100%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" style="stop-color: rgb(196 181 253); stop-opacity: 0.4" />
          <stop offset="100%" style="stop-color: rgb(99 102 241); stop-opacity: 0.14" />
        </linearGradient>
        <filter id="hero-glow-blur-b" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="20" result="blur" />
          <feMerge>
            <feMergeNode in="blur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>
      <circle
        cx="250"
        cy="250"
        r="210"
        stroke="url(#hero-arc-grad-b)"
        stroke-width="28"
        opacity="0.42"
        filter="url(#hero-glow-blur-b)"
      />
    </svg>
    <div class="hero-glow-vignette absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[var(--bg)]"></div>
  </div>

  <div class="relative z-[1] mx-auto flex w-full max-w-[1400px] flex-col px-6 pb-0 pt-0 md:flex-1 md:px-10 md:pb-2 md:pt-8 lg:px-16 lg:pb-4">
    <!-- Plain kicker (reference-style label, no pills) -->
    <p
      class="hero-kicker type-eyebrow fade-in pb-10 max-w-4xl md:mb-14"
      style="animation-delay: 0s;"
    >
      Based in Los Angeles, CA
    </p>

    <!-- Headline -->
    <h1
      class="fade-in hero-headline max-w-[16ch] text-[var(--text)] md:max-w-[20ch]"
      style="animation-delay: 0.08s;"
    >
      Websites that bring<br />
      Leads. All day.
    </h1>

    <!-- Subcopy + CTAs -->
    <div
      class="fade-in mt-8 flex flex-col gap-8 md:mt-16 md:gap-10 md:flex-row md:items-end md:justify-between lg:mt-20"
      style="animation-delay: 0.16s;"
    >
      <p class="type-lead max-w-xl">
        Custom coded websites with SEO, speed, lead capture, and attractive design +++ fully custom CMS and automations.<br />
        We got <span class="underline">all</span> of that plus more <span class="underline">covered</span> for you.
      </p>
      <div class="flex shrink-0 flex-col items-start gap-5 sm:flex-row sm:items-center sm:gap-8 md:flex-col md:items-end lg:flex-row lg:items-center">
        <a
          href="/portfolio"
          class="group inline-flex items-center gap-2 text-base font-medium text-[var(--text)] transition-colors hover:text-primary-500"
        >
          Our work
          <Icon
            name="arrow-right"
            size={18}
            class="transition-transform duration-300 group-hover:translate-x-1"
          />
        </a>
        <Button href="/contact" size="lg">
          Get started
        </Button>
      </div>
    </div>
  </div>

  <DesignBooklet />
</section>

<style>
  .hero-glow-svg {
    position: absolute;
    pointer-events: none;
  }

  .hero-glow-svg--a {
    width: min(120vw, 720px);
    height: min(120vw, 720px);
    right: -18%;
    top: -8%;
    transform: rotate(-12deg);
    opacity: 0.72;
  }

  .hero-glow-svg--b {
    width: min(95vw, 520px);
    height: min(95vw, 520px);
    right: 8%;
    bottom: -20%;
    transform: rotate(18deg);
    opacity: 0.65;
  }

  .hero-glow-vignette {
    pointer-events: none;
  }

  :global(.light) .hero-glow-svg--a,
  :global(.light) .hero-glow-svg--b {
    opacity: 0.42;
  }

  @media (max-width: 1023px) {
    .hero-glow-svg--a {
      top: 6%;
      right: -20%;
    }

    .hero-glow-svg--b {
      bottom: -32%;
      right: 4%;
    }
  }

  .hero-kicker {
    font-family: var(--font-body);
  }

  .hero-headline {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(2.875rem, 7vw, 5.5rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
  }
</style>
