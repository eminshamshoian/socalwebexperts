---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { stats } from '../../data/site';
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Animated shader canvas — covers the full section -->
  <div id="hero-shader-bg" class="absolute inset-0 z-0"></div>

  <!-- Dark overlay so text stays legible over the shader -->
  <div class="absolute inset-0 z-0 bg-black/55 pointer-events-none"></div>

  <!-- Fade to page background at the very bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-40 z-0 pointer-events-none"
       style="background: linear-gradient(to bottom, transparent, var(--bg))"></div>

  <div class="container py-24 md:py-32 relative z-10">
    <!-- Oversized Centered Hero – Ramotion style -->
    <div class="w-full max-w-5xl mx-auto flex flex-col items-center">
      <!-- Eyebrow -->
      <div class="fade-in mb-6">
        <span class="inline-flex items-center gap-2 px-4 py-2 mt-8 rounded-full border border-[var(--border)] text-sm text-[var(--text-secondary)]">
          <span class="w-2 h-2 rounded-full bg-primary-500 animate-pulse"></span>
          Built for speed, trust & leads
        </span>
      </div>

      <!-- Massive Headline -->
      <h1 class="text-[var(--text)] text-center mb-8 fade-in" style="animation-delay: 0.1s;">
        Websites built to<br/>
        <span class="gradient-text">bring you customers</span>
      </h1>

      <!-- Subtitle – centered block -->
      <p class="text-xl md:text-2xl text-[var(--text-secondary)] text-center w-full max-w-2xl mx-auto mb-8 leading-relaxed fade-in py-10" style="animation-delay: 0.2s;">
        Need a Website? We'll give you a fast, secure, Google-ready system that turns visitors into calls, quote requests, and booked jobs.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8 fade-in" style="animation-delay: 0.3s;">
        <Button href="/contact" size="lg">
          Get More Customers
        </Button>
        <Button href="/portfolio" variant="secondary" size="lg">
          View Work
          <Icon name="arrow-right" size={18} />
        </Button>
      </div>

      <!-- Trust Line -->
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-[var(--text-secondary)] fade-in" style="animation-delay: 0.4s;">
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
          Fast loading
        </span>
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
          SEO foundation
        </span>
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
          Done-for-you
        </span>
      </div>
    </div>

    <!-- Browser Mockup Below Hero -->
    <div class="w-full max-w-4xl mx-auto my-16 fade-in" style="animation-delay: 0.5s;">
      <div class="relative">
        <!-- Browser Window -->
        <div class="relative bg-[var(--bg-secondary)] rounded-2xl border border-[var(--border)] shadow-2xl shadow-black/30 overflow-hidden">
          <!-- Browser Header -->
          <div class="flex items-center gap-2 px-5 py-3.5 bg-[var(--bg-tertiary)] border-b border-[var(--border)]">
            <div class="flex gap-2">
              <div class="w-3 h-3 rounded-full bg-[#FF5F57]"></div>
              <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
              <div class="w-3 h-3 rounded-full bg-[#28CA41]"></div>
            </div>
            <div class="flex-1 mx-4">
              <div class="flex items-center gap-2 bg-[var(--bg)] rounded-lg px-4 py-2 text-xs text-[var(--text-secondary)]">
                <svg class="w-3 h-3 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                </svg>
                <span>theautoguys.com</span>
              </div>
            </div>
          </div>
          
          <!-- Screenshot -->
          <div class="bg-[var(--bg)]">
            <img 
              src="https://res.cloudinary.com/ds85pv6ht/image/upload/v1770167617/hero-mockup_tqloss.png" 
              alt="Example website design by SoCal Web Experts - The Auto Guys car dealership website with modern design and conversion-focused layout" 
              class="w-full h-auto block"
              loading="eager"
            />
          </div>
        </div>

        <!-- Floating badge -->
        <div class="absolute -bottom-4 -left-4 md:-bottom-6 md:-left-6 bg-[var(--bg)] border border-[var(--border)] rounded-2xl px-4 py-3 shadow-xl flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-green-500/15 flex items-center justify-center">
            <Icon name="trending-up" size={18} class="text-green-500" />
          </div>
          <div>
            <div class="text-xs text-[var(--text-secondary)]">Conversions</div>
            <div class="text-lg font-bold text-[var(--text)]">+127%</div>
          </div>
        </div>

        <!-- Live badge -->
        <a 
          href="https://www.autoguysla.com/" 
          target="_blank" 
          rel="noopener noreferrer"
          class="absolute -top-3 -right-3 md:-top-4 md:-right-4 bg-primary-500 hover:bg-primary-600 text-white rounded-full px-4 py-2 shadow-lg text-xs font-medium transition-all duration-300 hover:shadow-xl"
        >
          Live Project ↗
        </a>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="my-16 py-12 border-t border-white/10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-12">
        {stats.map((stat, index) => (
          <div class="text-center fade-in" style={`animation-delay: ${0.5 + index * 0.08}s`}>
            <div class="text-4xl md:text-5xl font-bold text-[var(--text)] mb-2 tracking-tight">
              {stat.value}<span class="text-primary-500">{stat.suffix}</span>
            </div>
            <div class="text-sm text-[var(--text-secondary)] tracking-wide">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import * as THREE from 'three';

  function initHeroShader() {
    const container = document.getElementById('hero-shader-bg');
    if (!container) return;

    const w = container.clientWidth;
    const h = container.clientHeight;

    const scene    = new THREE.Scene();
    const camera   = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    renderer.setSize(w, h);
    renderer.domElement.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;display:block;';
    container.appendChild(renderer.domElement);

    const material = new THREE.ShaderMaterial({
      uniforms: {
        iTime:       { value: 0 },
        iResolution: { value: new THREE.Vector2(w, h) },
      },
      vertexShader: `void main() { gl_Position = vec4(position, 1.0); }`,
      fragmentShader: `
        uniform float iTime;
        uniform vec2  iResolution;

        #define NUM_OCTAVES 3

        float rand(vec2 n) {
          return fract(sin(dot(n, vec2(12.9898, 4.1414))) * 43758.5453);
        }

        float noise(vec2 p) {
          vec2 ip = floor(p);
          vec2 u  = fract(p);
          u = u * u * (3.0 - 2.0 * u);
          return mix(
            mix(rand(ip),                  rand(ip + vec2(1.0, 0.0)), u.x),
            mix(rand(ip + vec2(0.0, 1.0)), rand(ip + vec2(1.0, 1.0)), u.x),
            u.y
          );
        }

        float fbm(vec2 x) {
          float v = 0.0; float a = 0.3;
          vec2 shift = vec2(100.0);
          mat2 rot = mat2(cos(0.5), sin(0.5), -sin(0.5), cos(0.5));
          for (int i = 0; i < NUM_OCTAVES; ++i) {
            v += a * noise(x); x = rot * x * 2.0 + shift; a *= 0.4;
          }
          return v;
        }

        void main() {
          vec2 shake = vec2(sin(iTime * 1.2) * 0.005, cos(iTime * 2.1) * 0.005);
          vec2 p = ((gl_FragCoord.xy + shake * iResolution.xy) - iResolution.xy * 0.5)
                   / iResolution.y * mat2(6.0, -4.0, 4.0, 6.0);
          vec2 v;
          vec4 o = vec4(0.0);
          float f = 2.0 + fbm(p + vec2(iTime * 5.0, 0.0)) * 0.5;

          for (float i = 0.0; i < 35.0; i++) {
            v = p + cos(i * i + (iTime + p.x * 0.08) * 0.025 + i * vec2(13.0, 11.0)) * 3.5
              + vec2(sin(iTime * 3.0 + i) * 0.003, cos(iTime * 3.5 - i) * 0.003);

            float tailNoise = fbm(v + vec2(iTime * 0.5, i)) * 0.3 * (1.0 - (i / 35.0));

            // Orange → amber → gold palette
            vec4 auroraColors = vec4(
              0.85 + 0.15 * sin(i * 0.25 + iTime * 0.4),
              0.20 + 0.20 * cos(i * 0.35 + iTime * 0.5),
              0.00 + 0.06 * sin(i * 0.45 + iTime * 0.3),
              1.0
            );

            vec4 contrib = auroraColors
                         * exp(sin(i * i + iTime * 0.8))
                         / length(max(v, vec2(v.x * f * 0.015, v.y * 1.5)));
            float thinFactor = smoothstep(0.0, 1.0, i / 35.0) * 0.6;
            o += contrib * (1.0 + tailNoise * 0.8) * thinFactor;
          }

          o = tanh(pow(o / 100.0, vec4(1.6)));
          gl_FragColor = vec4(o.rgb * 1.2, 1.0);
        }
      `,
    });

    const mesh = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), material);
    scene.add(mesh);

    let frameId: number;
    let lastTime = 0;

    const animate = (ts: number) => {
      material.uniforms.iTime.value += Math.min((ts - lastTime) / 1000, 0.05);
      lastTime = ts;
      renderer.render(scene, camera);
      frameId = requestAnimationFrame(animate);
    };
    frameId = requestAnimationFrame(animate);

    const onResize = () => {
      const cw = container.clientWidth;
      const ch = container.clientHeight;
      renderer.setSize(cw, ch);
      material.uniforms.iResolution.value.set(cw, ch);
    };
    window.addEventListener('resize', onResize);

    // Pause when scrolled out of view
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { frameId = requestAnimationFrame(animate); }
          else { cancelAnimationFrame(frameId); }
        });
      },
      { threshold: 0 }
    );
    observer.observe(container);

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(frameId);
      window.removeEventListener('resize', onResize);
      observer.disconnect();
      material.dispose();
      renderer.dispose();
    }, { once: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroShader);
  } else {
    initHeroShader();
  }
</script>
