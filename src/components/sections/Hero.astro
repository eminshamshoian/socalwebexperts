---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { stats } from '../../data/site';
---

<section class="relative pt-24 flex flex-col overflow-hidden">
  <!-- Subtle ambient glow -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
  >
    <div
      class="absolute left-1/2 top-[60%] -translate-x-1/2 -translate-y-1/2 w-[min(900px,120vw)] h-[500px] rounded-full"
      style="background: radial-gradient(ellipse, rgba(132,204,22,0.06) 0%, rgba(132,204,22,0.02) 40%, transparent 70%); filter: blur(80px);"
    ></div>
  </div>

  <!-- Main content — pushed to bottom of viewport -->
  <div class="flex-1 flex flex-col justify-end mx-auto w-full max-w-[1400px] px-6 lg:px-16 pb-14 md:pb-20">

    <!-- Eyebrow -->
    <p
      class="fade-in pb-10 md:pb-14 text-[11px] md:text-xs tracking-[0.3em] uppercase text-[var(--text-secondary)] font-medium"
      style="animation-delay: 0s;"
    >
      Socal Web Experts <span text-primary-500>:</span> Based in Los Angeles, CA
    </p>

    <!-- Headline -->
    <h1
      class="fade-in hero-headline text-[var(--text)]"
      style="animation-delay: 0.12s;"
    >
      Websites that bring<br />
      Leads. <span class="font-serif italic font-normal">All day.</span>
    </h1>

    <!-- Subtitle + CTAs -->
    <div
      class="fade-in mt-10 md:mt-16 flex flex-col md:flex-row md:items-end md:justify-between gap-8 md:gap-16"
      style="animation-delay: 0.24s;"
    >
      <p class="text-base md:text-lg text-[var(--text-secondary)] max-w-md leading-relaxed">
        SEO, Speed, Contact Forms, Attractive Design. <br /> We got <span class="underline">all</span> of that plus more <span class="underline">covered</span> for you.
      </p>
      <div class="flex items-center gap-3 flex-shrink-0">
        <Button href="/contact" size="lg">
          Get Started
        </Button>
        <Button href="/portfolio" variant="secondary" size="lg">
          View Our Work
          <Icon name="arrow-right" size={18} />
        </Button>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16 pb-10 md:pb-16">
    <div class="border-t border-[var(--border)] pt-8 md:pt-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-12">
        {stats.map((stat, index) => (
          <div class="fade-in" style={`animation-delay: ${0.36 + index * 0.06}s`}>
            <div class="text-2xl md:text-3xl lg:text-4xl font-bold text-[var(--text)] tracking-tight">
              {stat.value}<span class="text-primary-500">{stat.suffix}</span>
            </div>
            <div class="text-xs md:text-sm text-[var(--text-secondary)] mt-1">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-headline {
    font-size: clamp(2.75rem, 8.5vw, 7.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    font-weight: 400;
  }
</style>
