---
import { processSteps } from '../../data/site';
---

<section class="py-24 md:py-32">
  <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16">
    <!-- Header -->
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 mb-16 md:mb-24">
      <div class="fade-in">
        <p class="text-[11px] md:text-xs tracking-[0.3em] uppercase text-[var(--text-secondary)] font-medium mb-6">
          Process
        </p>
        <h2 class="text-[var(--text)]">
          Simple. <span class="font-serif italic font-normal">Done-for-you.</span>
        </h2>
      </div>
      <div class="flex items-end fade-in" style="animation-delay: 0.1s;">
        <p class="text-lg md:text-xl text-[var(--text-secondary)] leading-relaxed max-w-lg">
          Four steps. No tech stress. You stay focused on your business.
        </p>
      </div>
    </div>

    <!-- Steps -->
    <div>
      {processSteps.map((step, index) => (
        <div
          class="process-step group grid grid-cols-1 md:grid-cols-[8rem_1fr] lg:grid-cols-[12rem_1fr] gap-4 md:gap-12 py-10 md:py-16 border-t border-[var(--border)] fade-in"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <!-- Massive serif number -->
          <div class="font-serif italic text-6xl md:text-7xl lg:text-[7rem] text-primary-500/15 leading-none tracking-tight transition-colors duration-700 group-hover:text-primary-500/30">
            0{step.step}
          </div>

          <!-- Content -->
          <div class="max-w-xl">
            <h3 class="text-xl md:text-2xl font-medium text-[var(--text)] mb-4 tracking-tight transition-colors duration-500 group-hover:text-primary-500">
              {step.title}
            </h3>
            <p class="text-[var(--text-secondary)] leading-relaxed text-base">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
