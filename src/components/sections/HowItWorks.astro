---
import Icon from '../ui/Icon.astro';
import { processSteps } from '../../data/site';
---

<section class="py-20 md:py-28">
  <div class="container">
    <div class="max-w-2xl mb-14 fade-in">
      <p class="text-primary-500 text-sm font-medium tracking-wide uppercase mb-3">
        Process
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-[var(--text)] mb-4">
        Simple process, real results
      </h2>
      <p class="text-[var(--text-secondary)] text-lg">
        From first call to launch, we keep things straightforward and on schedule.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-4">
      {processSteps.map((step, index) => (
        <div class="relative fade-in" style={`animation-delay: ${index * 0.1}s`}>
          <!-- Connector line (desktop) -->
          {index < processSteps.length - 1 && (
            <div class="hidden lg:block absolute top-5 left-[calc(50%+24px)] right-0 h-px bg-[var(--border)]"></div>
          )}
          
          <div class="relative">
            <!-- Step number -->
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full bg-primary-500 text-white flex items-center justify-center font-bold text-sm">
                {step.step}
              </div>
              <div class="lg:hidden flex-1 h-px bg-[var(--border)]"></div>
            </div>

            <h3 class="font-semibold text-[var(--text)] mb-2">
              {step.title}
            </h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
