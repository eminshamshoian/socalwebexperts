---
import Icon from '../ui/Icon.astro';
import { processSteps } from '../../data/site';
---

<section class="py-24 md:py-32 border-t border-[var(--border)]">
  <div class="container">
    <!-- Header -->
    <div class="max-w-3xl mb-20 fade-in">
      <p class="text-primary-500 text-sm font-medium tracking-widest uppercase mb-6">
        Process
      </p>
      <h2 class="text-[var(--text)] mb-8">
        Simple. Done-for-you.
      </h2>
      <p class="text-lg md:text-xl text-[var(--text-secondary)] leading-relaxed">
        Quick process, clear steps, and no tech stress.
      </p>
    </div>

    <!-- Steps – large editorial layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-0 border border-[var(--border)] rounded-2xl overflow-hidden">
      {processSteps.map((step, index) => (
        <div 
          class={`relative p-8 fade-in ${index < processSteps.length - 1 ? 'lg:border-r border-b lg:border-b-0 border-[var(--border)]' : ''}`}
          style={`animation-delay: ${index * 0.1}s`}
        >
          <!-- Large step number -->
          <div class="text-6xl md:text-7xl font-bold text-primary-500/15 mb-6 leading-none tracking-tighter">
            0{step.step}
          </div>

          <h3 class="text-[var(--text)] mb-4">
            {step.title}
          </h3>
          <p class="text-[var(--text-secondary)] leading-relaxed">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
