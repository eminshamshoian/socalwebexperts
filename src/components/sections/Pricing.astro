---
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';
import { pricingModels } from '../../data/site';
---

<section class="pt-24 md:pt-32">
  <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16">
    <!-- Header -->
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 mb-16 md:mb-24">
      <div class="fade-in">
        <p class="text-[11px] md:text-xs tracking-[0.3em] uppercase text-[var(--text-secondary)] font-medium mb-6">
          Pricing
        </p>
        <h2 class="text-[var(--text)]">
          Choose your <span class="font-serif italic font-normal">growth path</span>
        </h2>
      </div>
      <div class="flex items-end fade-in" style="animation-delay: 0.1s;">
        <p class="text-lg md:text-xl text-[var(--text-secondary)] leading-relaxed max-w-lg">
          $0 down monthly or one-time ownership build. Both designed to bring more leads.
        </p>
      </div>
    </div>

    <!-- Stacked Cards -->
    <div class="space-y-6">
      {pricingModels.map((plan, index) => (
        <div
          class={`rounded-lg overflow-hidden fade-in ${plan.highlighted ? 'bg-primary-400' : 'border border-[var(--border)]'}`}
          style={`animation-delay: ${index * 0.1}s`}
        >
          <div class="grid grid-cols-1 md:grid-cols-2">
            <!-- Left: Plan details -->
            <div class="p-8 md:p-10 lg:p-12">
              <h3 class={`text-base font-medium pb-8 ${plan.highlighted ? 'text-primary-900' : 'text-[var(--text)]'}`}>
                {plan.title}
              </h3>

              <div class="flex items-baseline gap-3 pb-2">
                <span class={`text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter ${plan.highlighted ? 'text-primary-900' : 'text-[var(--text)]'}`}>
                  {plan.upfront}
                </span>
                {plan.upfront !== '$0' && (
                  <span class={`text-base ${plan.highlighted ? 'text-primary-800' : 'text-[var(--text-secondary)]'}`}>upfront</span>
                )}
              </div>
              <p class={`text-sm pb-8 ${plan.highlighted ? 'text-primary-800' : 'text-[var(--text-secondary)]'}`}>
                + {plan.monthly}/mo for hosting & support
              </p>

              <p class={`leading-relaxed pb-10 max-w-sm ${plan.highlighted ? 'text-primary-800' : 'text-[var(--text-secondary)]'}`}>
                {plan.description}
              </p>

              {plan.highlighted ? (
                <a
                  href="/contact"
                  class="inline-flex items-center justify-center gap-2 font-medium rounded-md px-8 py-3.5 text-base tracking-tight bg-primary-900 text-white shadow-[4px_4px_0px_0px_#1a2e05] hover:shadow-[2px_2px_0px_0px_#1a2e05] hover:translate-x-[2px] hover:translate-y-[2px] active:shadow-none active:translate-x-1 active:translate-y-1 transition-all duration-150"
                >
                  Start the Growth Plan
                  <Icon name="arrow-right" size={16} />
                </a>
              ) : (
                <Button href="/contact" variant="primary" size="lg">
                  Get the Ownership Build
                  <Icon name="arrow-right" size={16} />
                </Button>
              )}
            </div>

            <!-- Right: Features -->
            <div class={`p-8 md:p-10 lg:p-12 border-t md:border-t-0 md:border-l ${plan.highlighted ? 'border-primary-500/30' : 'border-[var(--border)]'}`}>
              <h4 class={`text-sm font-medium pb-8 ${plan.highlighted ? 'text-primary-900' : 'text-[var(--text)]'}`}>
                What's included
              </h4>
              <ul class="space-y-4">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <Icon name="check" size={16} class={`mt-0.5 shrink-0 ${plan.highlighted ? 'text-primary-900' : 'text-primary-500'}`} />
                    <span class={`text-sm ${plan.highlighted ? 'text-primary-900' : 'text-[var(--text)]'}`}>
                      {feature}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="text-[var(--text-secondary)] text-sm pt-5 fade-in">
      No tech stress · Fast turnaround · Clear support
    </p>
  </div>
</section>
