---
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';
import { pricingModels } from '../../data/site';
---

<section class="py-24 md:py-32 bg-[var(--bg-secondary)] border-t border-[var(--border)]">
  <div class="container">
    <!-- Header – centered -->
    <div class="max-w-3xl mx-auto text-center mb-20 fade-in">
      <p class="text-primary-500 text-sm font-medium tracking-widest uppercase mb-6">
        Pricing
      </p>
      <h2 class="text-[var(--text)] mb-8">
        Choose your growth path
      </h2>
      <p class="text-lg md:text-xl text-[var(--text-secondary)] leading-relaxed">
        $0 down monthly or one-time ownership build. Both are designed to bring more leads.
      </p>
    </div>

    <!-- Pricing cards -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 max-w-5xl mx-auto">
      {pricingModels.map((plan, index) => (
        <div 
          class={`relative p-8 bg-[var(--bg)] border rounded-3xl fade-in transition-all duration-300 hover:-translate-y-1 ${plan.highlighted ? 'border-primary-500 shadow-[0_0_60px_rgba(249,115,22,0.08)]' : 'border-[var(--border)]'}`}
          style={`animation-delay: ${index * 0.1}s`}
        >
          {plan.highlighted && (
            <div class="absolute -top-4 left-8 px-5 py-1.5 bg-primary-500 text-white text-xs font-semibold rounded-full tracking-wide">
              Most Popular
            </div>
          )}

          <div class="mb-8">
            <h3 class="text-xl font-semibold text-[var(--text)] mb-4">
              {plan.title}
            </h3>
            <p class="text-[var(--text-secondary)]">
              {plan.subtitle}
            </p>
          </div>

          <!-- Price -->
          <div class="mb-8 py-8 border-b border-[var(--border)]">
            <div class="flex items-baseline gap-2">
              <span class="text-5xl md:text-6xl font-bold text-[var(--text)] tracking-tight">{plan.upfront}</span>
              {plan.upfront !== '$0' && <span class="text-lg text-[var(--text-secondary)]">Total</span>}
            </div>
            <p class="text-[var(--text-secondary)] mt-2">
              + {plan.monthly}/mo for hosting & support
            </p>
          </div>

          <!-- Features -->
          <ul class="space-y-4 mb-10">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-primary-500/15 flex items-center justify-center shrink-0 mt-0.5">
                  <Icon name="check" size={12} class="text-primary-500" />
                </div>
                <span class="text-[var(--text)]">{feature}</span>
              </li>
            ))}
          </ul>

          <Button
            href="/contact"
            variant={plan.highlighted ? 'primary' : 'secondary'}
            fullWidth
            size="lg"
          >
            {plan.id === 'growth' ? 'Start the Growth Plan' : 'Get the Ownership Build'}
          </Button>
        </div>
      ))}
    </div>

    <!-- Footer note -->
    <p class="text-center text-[var(--text-secondary)] my-8 fade-in">
      No tech stress • Fast turnaround • Clear support
    </p>
  </div>
</section>
