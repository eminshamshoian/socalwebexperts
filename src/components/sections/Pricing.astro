---
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';
import { pricingModels } from '../../data/site';
---

<section class="pt-24 md:pt-32">
  <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 mb-16 md:mb-24">
      <div class="fade-in">
        <p class="type-eyebrow mb-6">
          Pricing
        </p>
        <h2 class="text-[var(--text)]">
          One package. Clear numbers.
        </h2>
      </div>
      <div class="flex items-end fade-in" style="animation-delay: 0.1s;">
        <p class="type-lead max-w-lg">
          Custom site, secure hosting, and predictable ongoing costs. No plan maze.
        </p>
      </div>
    </div>

    <div class="w-full">
      {pricingModels.map((plan, index) => (
        <div
          class={`rounded-lg overflow-hidden fade-in ${plan.highlighted ? 'bg-primary-400' : 'border border-[var(--border)]'}`}
          style={`animation-delay: ${index * 0.1}s`}
        >
          <div class="grid grid-cols-1 md:grid-cols-2">
            <div class="p-8 md:p-10 lg:p-14 xl:p-16">
              <p
                class={`text-xs uppercase tracking-[0.2em] mb-2 ${plan.highlighted ? 'text-black' : 'text-[var(--text-secondary)]'}`}
              >
                {plan.subtitle}
              </p>
              <h3
                class={`text-base font-medium pb-6 ${plan.highlighted ? 'text-black' : 'text-[var(--text)]'}`}
              >
                {plan.title}
              </h3>

              {plan.upfrontPrefix && (
                <p class={`text-sm pb-1 ${plan.highlighted ? 'text-black' : 'text-[var(--text-secondary)]'}`}>
                  {plan.upfrontPrefix}
                </p>
              )}
              <div class="flex items-baseline gap-3 pb-2">
                <span
                  class={`text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter ${plan.highlighted ? 'text-black' : 'text-[var(--text)]'}`}
                >
                  {plan.upfront}
                </span>
                <span class={`text-base ${plan.highlighted ? 'text-black' : 'text-[var(--text-secondary)]'}`}>
                  {plan.upfrontLabel ?? 'upfront'}
                </span>
              </div>
              <p class={`text-sm pb-10 ${plan.highlighted ? 'text-black' : 'text-[var(--text-secondary)]'}`}>
                {plan.yearly
                  ? `${plan.monthly} a month or ${plan.yearly} yearly`
                  : `+ ${plan.monthly}/mo hosting`}
              </p>

              {plan.highlighted ? (
                <a
                  href="/contact"
                  class="inline-flex items-center justify-center gap-2 font-medium rounded-md px-8 py-3.5 text-base tracking-tight bg-primary-900 text-white shadow-[4px_4px_0px_0px_#1a2e05] hover:shadow-[2px_2px_0px_0px_#1a2e05] hover:translate-x-[2px] hover:translate-y-[2px] active:shadow-none active:translate-x-1 active:translate-y-1 transition-all duration-150"
                >
                  Get started
                  <Icon name="arrow-right" size={16} />
                </a>
              ) : (
                <Button href="/contact" variant="primary" size="lg">
                  Get started
                  <Icon name="arrow-right" size={16} />
                </Button>
              )}
            </div>

            <div
              class={`p-8 md:p-10 lg:p-14 xl:p-16 border-t md:border-t-0 md:border-l ${plan.highlighted ? 'border-primary-500/30' : 'border-[var(--border)]'}`}
            >
              <h4
                class={`text-sm font-medium pb-8 ${plan.highlighted ? 'text-black' : 'text-[var(--text)]'}`}
              >
                What's included
              </h4>
              <ul class="space-y-4">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <Icon
                      name="check"
                      size={16}
                      class={`mt-0.5 shrink-0 ${plan.highlighted ? 'text-black' : 'text-primary-500'}`}
                    />
                    <span class={`text-sm ${plan.highlighted ? 'text-black' : 'text-[var(--text)]'}`}>
                      {feature}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
