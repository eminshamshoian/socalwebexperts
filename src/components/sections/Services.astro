---
import Icon from '../ui/Icon.astro';
import { services } from '../../data/site';
---

<section id="services" class="py-24 md:py-32 scroll-mt-24">
  <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16">
    <div class="fade-in max-w-2xl mb-16 md:mb-24">
      <h2 class="text-[var(--text)] mb-4 md:mb-6">
        Our Services
      </h2>
      <p class="type-lead">
        From a site that sells your business at a glance to social and paid campaigns that keep you visible. We handle the digital pieces so you can focus on customers.
      </p>
    </div>

    <!-- Three-column service grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-14 md:gap-10 lg:gap-16">
      {services.map((service, index) => (
        <article
          class="fade-in flex flex-col text-left"
          style={`animation-delay: ${0.08 + index * 0.06}s`}
        >
          <div class="mb-6 text-[var(--text)]">
            <Icon name={service.icon} size={28} class="text-primary-500" />
          </div>
          <h3 class="text-[var(--text)] pb-3">{service.title}</h3>
          <p class="type-body-card flex-1 pb-8">
            {service.shortDescription}
          </p>
          <a
            href={`/services/${service.slug}`}
            class="type-caption font-medium text-[var(--text)] inline-flex items-center gap-1.5 transition-colors duration-300 hover:text-primary-500 group/vm"
          >
            View more
            <Icon
              name="arrow-right"
              size={16}
              class="transition-transform duration-300 group-hover/vm:translate-x-0.5"
            />
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
