---
import { stats } from '../../data/site';
---

<section class="stats-strip border-y border-[var(--border)]/50 bg-[var(--bg)] py-12 md:py-16">
  <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16">
    <div class="grid grid-cols-2 gap-y-8 gap-x-6 md:grid-cols-4 md:gap-10">
      {stats.map((stat, index) => (
        <div class="fade-in text-center md:text-left" style={`animation-delay: ${0.08 + index * 0.05}s`}>
          <div class="text-xl font-medium tabular-nums tracking-tight text-[var(--text)]/70 md:text-2xl">
            {stat.value}<span class="text-primary-500/70">{stat.suffix}</span>
          </div>
          <div class="type-eyebrow mt-1.5">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
