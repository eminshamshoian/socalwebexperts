---
import Icon from '../ui/Icon.astro';
import { testimonials } from '../../data/site';
---

<section class="py-24 md:py-32 border-t border-[var(--border)]">
  <div class="container">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-20">
      <div class="fade-in">
        <p class="text-primary-500 text-sm font-medium tracking-widest uppercase mb-6">
          Testimonials
        </p>
        <h2 class="text-[var(--text)]">
          What our<br class="hidden md:block"/> partners say
        </h2>
      </div>
      <div class="flex-shrink-0 fade-in" style="animation-delay: 0.1s;">
        <img 
          src="https://res.cloudinary.com/ds85pv6ht/image/upload/v1770167617/yelp-rating_m1s29p.webp" 
          alt="SoCal Web Experts Yelp Rating - 5 Star Reviews" 
          style="height: 60px; width: auto; max-width: 130px;"
        />
      </div>
    </div>

    <!-- Featured testimonial – large blockquote -->
    <div class="mb-16 fade-in" style="animation-delay: 0.15s;">
      <div class="relative p-8 md:p-12 bg-[var(--bg-secondary)] border border-[var(--border)] rounded-3xl">
        <!-- Large quote mark -->
        <div class="text-primary-500/20 text-[8rem] md:text-[12rem] leading-none font-serif absolute top-4 left-6 md:top-4 md:left-10 select-none">"</div>
        
        <div class="relative">
          <p class="text-xl md:text-2xl lg:text-3xl text-[var(--text)] leading-relaxed mb-8 max-w-4xl font-light">
            {testimonials[0].quote}
          </p>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-primary-500/15 flex items-center justify-center text-primary-500 font-semibold text-base">
              {testimonials[0].name.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <div class="font-semibold text-[var(--text)]">{testimonials[0].name}</div>
              <div class="text-sm text-[var(--text-secondary)]">{testimonials[0].company}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Remaining testimonials grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.slice(1).map((testimonial, index) => (
        <div 
          class="p-8 bg-[var(--bg-secondary)] border border-[var(--border)] rounded-2xl fade-in"
          style={`animation-delay: ${0.2 + index * 0.06}s`}
        >
          <!-- Stars -->
          <div class="flex items-center gap-1 mb-6">
            {Array.from({ length: testimonial.rating }).map(() => (
              <Icon name="star-filled" size={14} class="text-amber-500" />
            ))}
          </div>

          <!-- Quote -->
          <p class="text-[var(--text)] mb-8 leading-relaxed text-base">
            "{testimonial.quote}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 py-6 border-t border-[var(--border)]">
            <div class="w-10 h-10 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center text-[var(--text)] font-medium text-sm">
              {testimonial.name.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <div class="font-medium text-sm text-[var(--text)]">{testimonial.name}</div>
              <div class="text-xs text-[var(--text-secondary)]">{testimonial.company}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
