---
import ReviewRatings from '../ui/ReviewRatings.astro';
import YelpReview from '../ui/YelpReview.astro';
---

<section class="py-24 md:py-32" aria-labelledby="testimonials-heading">
  <div class="w-full max-w-[1600px] mx-auto px-6 md:px-8">
    <div class="max-w-3xl mx-auto mb-16 md:mb-20 flex flex-col items-center text-center">
      <div class="fade-in flex justify-center">
        <span class="type-eyebrow inline-flex items-center gap-2 mb-6">
          <span class="w-6 h-px bg-primary-500"></span>
          Reviews
          <span class="w-6 h-px bg-primary-500"></span>
        </span>
      </div>
      <h2 id="testimonials-heading" class="text-[var(--text)] fade-in text-center" style="animation-delay: 0.05s;">
        What customers say about us
      </h2>
      <p class="type-lead mt-6 max-w-xl mx-auto fade-in text-center" style="animation-delay: 0.1s;">
        Real feedback from local business owners, including verified reviews on Yelp and Google.
      </p>
    </div>

    <div class="grid lg:grid-cols-[minmax(240px,320px)_minmax(0,1fr)] gap-8 lg:gap-12 items-stretch max-w-5xl mx-auto">
      <div class="order-2 lg:order-1">
        <ReviewRatings />
      </div>
      <div class="order-1 lg:order-2">
        <YelpReview />
      </div>
    </div>
  </div>
</section>
