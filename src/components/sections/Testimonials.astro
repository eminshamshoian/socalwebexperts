---
import Icon from '../ui/Icon.astro';
import { testimonials } from '../../data/site';
---

<section class="py-20 md:py-28">
  <div class="container">
    <div class="max-w-2xl mb-14 fade-in">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-6">
        <div>
          <p class="text-primary-500 text-sm font-medium tracking-wide uppercase mb-3">
            Testimonials
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-[var(--text)]">
            What our clients say
          </h2>
        </div>
        <div class="flex-shrink-0">
          <img 
            src="https://res.cloudinary.com/ds85pv6ht/image/upload/v1770167617/yelp-rating_m1s29p.webp" 
            alt="SoCal Web Experts Yelp Rating - 5 Star Reviews" 
            style="height: 60px; width: auto; max-width: 120px;"
          />
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
      {testimonials.map((testimonial, index) => (
        <div 
          class="p-6 bg-[var(--bg-secondary)] border border-[var(--border)] rounded-xl fade-in"
          style={`animation-delay: ${index * 0.05}s`}
        >
          <!-- Stars -->
          <div class="flex items-center gap-0.5 mb-4">
            {Array.from({ length: testimonial.rating }).map(() => (
              <Icon name="star-filled" size={14} class="text-amber-500" />
            ))}
          </div>

          <!-- Quote -->
          <p class="text-[var(--text)] mb-6 leading-relaxed">
            "{testimonial.quote}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center text-[var(--text)] font-medium text-sm">
              {testimonial.name.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <div class="font-medium text-sm text-[var(--text)]">{testimonial.name}</div>
              <div class="text-xs text-[var(--text-secondary)]">
                {testimonial.company}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
