---
import Icon from '../ui/Icon.astro';
import { valueProps } from '../../data/site';
---

<section class="py-20 md:py-28 bg-[var(--bg-secondary)]">
  <div class="container">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <!-- Left Content -->
      <div class="lg:sticky lg:top-28">
        <p class="text-primary-500 text-sm font-medium tracking-wide uppercase mb-3 fade-in">
          Why Us
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-[var(--text)] mb-5 fade-in" style="animation-delay: 0.05s;">
          Built different.<br />Built to perform.
        </h2>
        <p class="text-[var(--text-secondary)] text-lg leading-relaxed mb-8 fade-in" style="animation-delay: 0.1s;">
          We don't use WordPress templates or page builders. Every site is hand-coded for speed, SEO, and conversions. That's why our clients see real results.
        </p>
        
        <!-- Key differentiator -->
        <div class="p-5 bg-[var(--bg)] border border-[var(--border)] rounded-xl fade-in" style="animation-delay: 0.15s;">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
            <span class="text-sm font-medium text-[var(--text)]">Average PageSpeed score</span>
          </div>
          <div class="flex items-baseline gap-2">
            <span class="text-4xl font-bold text-[var(--text)]">98</span>
            <span class="text-sm text-[var(--text-secondary)]">/ 100</span>
          </div>
          <p class="text-xs text-[var(--text-secondary)] mt-2">vs. industry average of 50</p>
        </div>
      </div>

      <!-- Right - Features Grid -->
      <div class="grid sm:grid-cols-2 gap-4">
        {valueProps.map((prop, index) => (
          <div 
            class="p-5 bg-[var(--bg)] border border-[var(--border)] rounded-xl fade-in"
            style={`animation-delay: ${0.1 + index * 0.05}s`}
          >
            <div class="w-9 h-9 rounded-lg bg-primary-500/10 flex items-center justify-center mb-4">
              <Icon name={prop.icon} size={18} class="text-primary-500" />
            </div>
            <h3 class="font-semibold text-[var(--text)] mb-1.5">
              {prop.title}
            </h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              {prop.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
