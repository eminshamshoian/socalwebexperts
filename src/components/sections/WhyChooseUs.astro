---
import Icon from '../ui/Icon.astro';
import { valueProps } from '../../data/site';
---

<section class="py-24 md:py-32 bg-[var(--bg-secondary)] border-t border-[var(--border)]">
  <div class="container">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left Content – Sticky editorial column -->
      <div class="lg:sticky lg:top-32">
        <p class="text-primary-500 text-sm font-medium tracking-widest uppercase mb-6 fade-in">
          Why Us
        </p>
        <h2 class="text-[var(--text)] mb-8 fade-in" style="animation-delay: 0.05s;">
          Most sites look fine.<br/>Few actually convert.
        </h2>
        <p class="text-lg md:text-xl text-[var(--text-secondary)] leading-relaxed mb-8 fade-in" style="animation-delay: 0.1s;">
          We build fast, clean, modern websites with one goal: more customers. Your website should produce customers, not excuses.
        </p>

        <!-- Callout card -->
        <div class="p-8 rounded-2xl border border-[var(--border)] bg-[var(--bg)] my-8 fade-in" style="animation-delay: 0.15s;">
          <p class="text-base font-semibold text-[var(--text)] mb-4">People search first. Then they call.</p>
          <p class="text-[var(--text-secondary)] leading-relaxed">When your site is built right, it builds trust fast and makes contacting you effortless.</p>
        </div>
        
        <!-- Lighthouse Score -->
        <div class="fade-in" style="animation-delay: 0.2s;">
          <div class="rounded-2xl overflow-hidden border border-primary-500/20 shadow-[0_0_40px_rgba(249,115,22,0.08)]">
            <img 
              src="https://res.cloudinary.com/ds85pv6ht/image/upload/v1770169798/lighthouse-score_qpwbbq.png" 
              alt="Lighthouse Performance Scores - SoCal Web Experts" 
              class="w-full h-auto"
            />
          </div>
        </div>
      </div>

      <!-- Right – Feature cards -->
      <div class="grid sm:grid-cols-2 gap-6">
        {valueProps.map((prop, index) => (
          <div 
            class="group p-8 bg-[var(--bg)] border border-[var(--border)] rounded-2xl hover:border-[var(--text)]/15 transition-all duration-300 fade-in"
            style={`animation-delay: ${0.1 + index * 0.06}s`}
          >
            <div class="w-11 h-11 rounded-xl bg-primary-500/10 flex items-center justify-center mb-6 group-hover:bg-primary-500/20 transition-colors duration-300">
              <Icon name={prop.icon} size={20} class="text-primary-500" />
            </div>
            <h3 class="text-[var(--text)] mb-4">
              {prop.title}
            </h3>
            <p class="text-[var(--text-secondary)] leading-relaxed">
              {prop.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
