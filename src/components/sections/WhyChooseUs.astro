---
import Icon from '../ui/Icon.astro';
---

<section class="py-24 md:py-32 bg-[var(--bg-secondary)] border-t border-[var(--border)] overflow-hidden">
  <div class="container">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">

      <!-- Left: headline + stacked display cards -->
      <div>
        <p class="text-primary-500 text-sm font-medium tracking-widest uppercase mb-6 fade-in">
          Why Us
        </p>
        <h2 class="text-[var(--text)] pb-6 fade-in" style="animation-delay: 0.05s;">
          Built to convert,<br />not just look good.
        </h2>
        <p class="text-lg text-[var(--text-secondary)] leading-relaxed pb-12 max-w-md fade-in" style="animation-delay: 0.1s;">
          Speed, structure, and strategy — every site we ship is engineered to turn visitors into customers.
        </p>

        <!-- Stacked display cards -->
        <div class="display-cards fade-in" style="animation-delay: 0.2s;">
          <div class="display-card display-card--1">
            <div class="display-card__head">
              <span class="display-card__icon">
                <Icon name="zap" size={16} class="text-primary-400" />
              </span>
              <span class="display-card__title">Speed-First</span>
            </div>
            <p class="display-card__desc">Sub-second loads that keep visitors engaged.</p>
          </div>

          <div class="display-card display-card--2">
            <div class="display-card__head">
              <span class="display-card__icon">
                <Icon name="search" size={16} class="text-primary-400" />
              </span>
              <span class="display-card__title">SEO-Ready</span>
            </div>
            <p class="display-card__desc">Structured for Google from day one.</p>
          </div>

          <div class="display-card display-card--3">
            <div class="display-card__head">
              <span class="display-card__icon">
                <Icon name="target" size={16} class="text-primary-400" />
              </span>
              <span class="display-card__title">Conversion-Focused</span>
            </div>
            <p class="display-card__desc">Layouts designed to drive calls and leads.</p>
          </div>
        </div>
      </div>

      <!-- Right: Lighthouse image -->
      <div class="fade-in flex items-center justify-center" style="animation-delay: 0.25s;">
        <div class="rounded-2xl overflow-hidden border border-primary-500/20 shadow-[0_0_60px_rgba(249,115,22,0.1)]">
          <img
            src="https://res.cloudinary.com/ds85pv6ht/image/upload/v1770169798/lighthouse-score_qpwbbq.png"
            alt="Lighthouse Performance Scores - SoCal Web Experts"
            class="w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Stacked display cards ── */
  .display-cards {
    display: grid;
    grid-template-areas: 'stack';
    place-items: start;
    min-height: 220px;
  }

  .display-card {
    grid-area: stack;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.75rem;
    width: 20rem;
    max-width: 100%;
    padding: 1rem 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg);
    transform: skewY(-8deg);
    user-select: none;
    transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    backdrop-filter: blur(8px);
    overflow: hidden;
  }

  /* Right-edge fade (mimics the reference's after pseudo) */
  .display-card::after {
    content: '';
    position: absolute;
    right: -4px;
    top: -5%;
    height: 110%;
    width: 18rem;
    background: linear-gradient(to left, var(--bg-secondary), transparent);
    pointer-events: none;
  }

  /* Card 1: back, grayscale */
  .display-card--1 {
    filter: grayscale(100%);
  }

  .display-card--1::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 0.75rem;
    background: var(--bg);
    opacity: 0.5;
    transition: opacity 0.5s;
    z-index: 1;
  }

  .display-card--1:hover {
    transform: skewY(-8deg) translateY(-2.5rem);
    filter: grayscale(0%);
  }

  .display-card--1:hover::before {
    opacity: 0;
  }

  /* Card 2: middle, offset + grayscale */
  .display-card--2 {
    transform: skewY(-8deg) translate(3rem, 2.5rem);
    filter: grayscale(100%);
  }

  .display-card--2::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 0.75rem;
    background: var(--bg);
    opacity: 0.5;
    transition: opacity 0.5s;
    z-index: 1;
  }

  .display-card--2:hover {
    transform: skewY(-8deg) translate(3rem, 0rem);
    filter: grayscale(0%);
  }

  .display-card--2:hover::before {
    opacity: 0;
  }

  /* Card 3: front, full color */
  .display-card--3 {
    transform: skewY(-8deg) translate(6rem, 5rem);
    border-color: rgba(249, 115, 22, 0.2);
  }

  .display-card--3:hover {
    transform: skewY(-8deg) translate(6rem, 2.5rem);
  }

  /* ── Inner elements ── */
  .display-card__head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    z-index: 2;
  }

  .display-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    background: rgba(249, 115, 22, 0.15);
    flex-shrink: 0;
  }

  .display-card__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary-500);
  }

  .display-card__desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
    position: relative;
    z-index: 2;
    margin: 0;
  }

  /* Mobile: tighter offsets */
  @media (max-width: 639px) {
    .display-card {
      width: 16rem;
    }

    .display-card--2 {
      transform: skewY(-8deg) translate(2rem, 2.5rem);
    }

    .display-card--2:hover {
      transform: skewY(-8deg) translate(2rem, 0rem);
    }

    .display-card--3 {
      transform: skewY(-8deg) translate(4rem, 5rem);
    }

    .display-card--3:hover {
      transform: skewY(-8deg) translate(4rem, 2.5rem);
    }

    .display-card::after {
      width: 12rem;
    }
  }
</style>
