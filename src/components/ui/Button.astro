---
export interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  fullWidth?: boolean;
  class?: string;
  id?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  fullWidth = false,
  class: className = '',
  id,
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-medium rounded-full transition-all duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg)] tracking-tight';

const variants = {
  primary: 'bg-primary-500 text-white hover:bg-primary-600 active:bg-primary-700 shadow-[0_2px_20px_rgba(249,115,22,0.25)] hover:shadow-[0_4px_30px_rgba(249,115,22,0.35)]',
  secondary: 'bg-transparent text-[var(--text)] border border-[var(--text)]/20 hover:border-[var(--text)]/50 hover:bg-[var(--bg-secondary)]',
  ghost: 'text-[var(--text-secondary)] hover:text-[var(--text)] hover:bg-[var(--bg-secondary)]/70',
};

const sizes = {
  sm: 'px-5 py-2.5 text-sm gap-2',
  md: 'px-6 py-3 text-sm gap-2',
  lg: 'px-8 py-3.5 text-base gap-2',
};

const classes = [
  baseStyles,
  variants[variant],
  sizes[size],
  fullWidth ? 'w-full' : '',
  className,
].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} id={id}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} id={id}>
    <slot />
  </button>
)}
