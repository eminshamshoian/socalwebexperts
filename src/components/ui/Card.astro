---
export interface Props {
  padding?: 'none' | 'sm' | 'md' | 'lg';
  hover?: boolean;
  class?: string;
}

const {
  padding = 'md',
  hover = false,
  class: className = '',
} = Astro.props;

const baseStyles = 'bg-[var(--bg-secondary)] border border-[var(--border)] rounded-2xl backdrop-blur-sm';

const paddings = {
  none: '',
  sm: 'p-5',
  md: 'p-7',
  lg: 'p-10',
};

const hoverStyles = hover 
  ? 'hover:border-[var(--text)]/15 hover:-translate-y-1 transition-all duration-300 cursor-pointer' 
  : '';

const classes = [
  baseStyles,
  paddings[padding],
  hoverStyles,
  className,
].filter(Boolean).join(' ');
---

<div class={classes}>
  <slot />
</div>
