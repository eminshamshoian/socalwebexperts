---
import Icon from './Icon.astro';
import { yelpReview } from '../../data/site';

const platforms = [
  {
    id: 'yelp',
    name: 'Yelp',
    rating: 5,
    href: yelpReview.businessUrl,
    label: '5.0 on Yelp',
  },
  {
    id: 'google',
    name: 'Google',
    rating: 5,
    href: 'https://www.google.com/maps/search/?api=1&query=SoCal+Web+Experts+Glendale',
    label: '5.0 on Google',
  },
] as const;
---

<div class="review-ratings fade-in" aria-label="Review platform ratings">
  <p class="type-eyebrow mb-8">Rated 5 stars</p>

  <ul class="review-ratings__list">
    {platforms.map((platform) => (
      <li>
        <a
          href={platform.href}
          rel="nofollow noopener noreferrer"
          target="_blank"
          class="review-ratings__item group"
          aria-label={platform.label}
        >
          <span class="review-ratings__brand">
            {platform.id === 'yelp' ? (
              <svg class="review-ratings__logo review-ratings__logo--yelp" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="currentColor" d="M20.16 12.594l-4.995 1.433c-.961.272-1.61 1.168-1.607 2.163l.022 4.031c.004 1.252-1.431 2.08-2.514 1.462l-3.521-2.038c-.842-.488-1.912-.244-2.49.56L2.78 23.64C1.911 24.855.118 24.1.118 22.605l.016-4.291c.003-.961.56-1.826 1.422-2.21l4.15-1.845c.881-.391 1.242-1.502.765-2.365L3.95 7.145C3.238 5.856 4.56 4.32 5.967 4.84l4.444 1.702c.89.34 1.899-.06 2.28-.904l1.788-3.973C15.07.332 16.868.76 17.13 2.154l.879 4.775c.177.96.935 1.688 1.907 1.83l4.447.65c1.45.212 1.995 2.068.797 2.985l-4.999 2.2z"/>
              </svg>
            ) : (
              <svg class="review-ratings__logo review-ratings__logo--google" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
            )}
            <span class="review-ratings__name">{platform.name}</span>
          </span>

          <span class="review-ratings__score">
            <span class="review-ratings__number">5.0</span>
            <span class="review-ratings__stars" aria-hidden="true">
              {Array.from({ length: platform.rating }).map(() => (
                <Icon name="star-filled" size={14} class="text-amber-400" />
              ))}
            </span>
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .review-ratings {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    min-height: 100%;
  }

  .review-ratings__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .review-ratings__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.15rem;
    border: 1px solid var(--border);
    border-radius: 0;
    background: transparent;
    transition: border-color 0.25s ease, background-color 0.25s ease;
  }

  .review-ratings__item:hover {
    border-color: color-mix(in srgb, var(--text) 18%, transparent);
    background: var(--bg-secondary);
  }

  .review-ratings__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .review-ratings__logo {
    width: 1.35rem;
    height: 1.35rem;
    flex-shrink: 0;
  }

  .review-ratings__logo--yelp {
    color: #d32323;
  }

  .review-ratings__name {
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .review-ratings__score {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
  }

  .review-ratings__number {
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--text);
    tabular-nums: true;
    font-variant-numeric: tabular-nums;
  }

  .review-ratings__stars {
    display: inline-flex;
    align-items: center;
    gap: 0.12rem;
  }
</style>
