---
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---

<div class="scrollable-project-image" data-scrollable>
  <img
    src={src}
    alt={alt}
    loading="lazy"
  />
</div>

<style>
  .scrollable-project-image {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    cursor: pointer;
  }

  .scrollable-project-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: auto;
    display: block;
    will-change: transform;
  }

  @media (hover: hover) and (pointer: fine) {
    .scrollable-project-image img {
      transition: transform 6s cubic-bezier(0.25, 0.1, 0.25, 1);
    }
    .scrollable-project-image img.snap-back {
      transition: transform 0.4s cubic-bezier(0.33, 0, 0.2, 1);
    }
  }
</style>

<script>
  function initScrollableImages() {
    document.querySelectorAll<HTMLElement>('[data-scrollable]').forEach((container) => {
      const img = container.querySelector<HTMLImageElement>('img');
      if (!img || container.hasAttribute('data-init')) return;
      container.setAttribute('data-init', '');

      function getOverflow() {
        return Math.max(0, img!.offsetHeight - container.clientHeight);
      }

      // Desktop: hover to scroll, fast snap-back on leave
      container.addEventListener('mouseenter', () => {
        img!.classList.remove('snap-back');
        const overflow = getOverflow();
        if (overflow > 0) {
          img!.style.transform = `translateY(-${overflow}px)`;
        }
      });

      container.addEventListener('mouseleave', () => {
        img!.classList.add('snap-back');
        img!.style.transform = 'translateY(0)';
      });

      // Mobile: tap to toggle scroll, tap again to snap back
      let scrolled = false;
      container.addEventListener('touchend', (e) => {
        e.preventDefault();
        const overflow = getOverflow();
        if (overflow <= 0) return;

        if (!scrolled) {
          img!.style.transition = 'transform 6s cubic-bezier(0.25, 0.1, 0.25, 1)';
          img!.style.transform = `translateY(-${overflow}px)`;
          scrolled = true;
        } else {
          img!.style.transition = 'transform 0.4s cubic-bezier(0.33, 0, 0.2, 1)';
          img!.style.transform = 'translateY(0)';
          scrolled = false;
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollableImages);
  } else {
    initScrollableImages();
  }

  document.addEventListener('astro:after-swap', initScrollableImages);
</script>
