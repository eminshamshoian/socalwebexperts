---
export interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  title,
  subtitle,
  badge,
  align = 'center',
  class: className = '',
} = Astro.props;

const alignments = {
  left: 'text-left',
  center: 'text-center mx-auto',
};
---

<div class={`max-w-2xl ${alignments[align]} ${className}`}>
  {badge && (
    <p class="type-eyebrow mb-3">
      {badge}
    </p>
  )}
  <h2 class="text-[var(--text)] mb-4">
    <slot name="title">
      <Fragment set:html={title} />
    </slot>
  </h2>
  {subtitle && (
    <p class="type-lead">
      {subtitle}
    </p>
  )}
</div>
