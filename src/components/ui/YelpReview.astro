---
import Icon from './Icon.astro';
import { yelpReview } from '../../data/site';

const initials = yelpReview.authorName
  .split(' ')
  .map((part) => part[0])
  .join('')
  .slice(0, 2);
---

<article class="yelp-featured fade-in" aria-labelledby="yelp-review-heading">
  <div class="yelp-featured__stars" role="img" aria-label={`${yelpReview.rating} out of 5 stars`}>
    {Array.from({ length: yelpReview.rating }).map(() => (
      <Icon name="star-filled" size={18} class="text-amber-400" />
    ))}
  </div>

  <h3 id="yelp-review-heading" class="sr-only">Yelp review from {yelpReview.authorName}</h3>

  <blockquote class="yelp-featured__quote">
    <p>"{yelpReview.quote}"</p>
  </blockquote>

  <footer class="yelp-featured__author">
    <div class="yelp-featured__avatar" aria-hidden="true">{initials}</div>
    <div class="min-w-0">
      <cite class="yelp-featured__name not-italic">
        <a
          href={yelpReview.authorProfileUrl}
          rel="nofollow noopener noreferrer"
          target="_blank"
        >
          {yelpReview.authorName}
        </a>
      </cite>
      <p class="yelp-featured__role">Yelp Reviewer · {yelpReview.location}</p>
    </div>
  </footer>

  <div class="yelp-featured__embed" aria-hidden="true">
    <span
      class="yelp-review"
      data-review-id={yelpReview.reviewId}
      data-hostname="www.yelp.com"
    >
      Read
      <a href={yelpReview.authorProfileUrl} rel="nofollow noopener">Adena M.</a>'s
      <a href={yelpReview.reviewUrl} rel="nofollow noopener">review</a>
      of
      <a href={`https://www.yelp.com/biz/${yelpReview.businessId}`} rel="nofollow noopener">SoCal Web Experts</a>
      on
      <a href="https://www.yelp.com" rel="nofollow noopener">Yelp</a>
    </span>
  </div>
</article>

<style>
  .yelp-featured {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
    height: 100%;
    padding: 1.75rem 1.5rem 1.5rem;
    border-radius: 0;
    background: transparent;
    border: 1px solid var(--border);
  }

  .yelp-featured__stars {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }

  .yelp-featured__quote {
    margin: 0;
    flex: 1;
  }

  .yelp-featured__quote p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    font-style: normal;
    line-height: 1.7;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .yelp-featured__author {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-top: 0.35rem;
  }

  .yelp-featured__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .yelp-featured__name {
    display: block;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text);
  }

  .yelp-featured__name a {
    color: inherit;
    text-decoration: none;
  }

  .yelp-featured__name a:hover {
    color: var(--color-primary-500);
  }

  .yelp-featured__role {
    margin: 0.15rem 0 0;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--text-secondary);
  }

  .yelp-featured__embed {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .yelp-featured {
      padding: 1.75rem 1.5rem;
      gap: 1.5rem;
    }

    .yelp-featured__quote p {
      font-size: 1.0625rem;
    }
  }
</style>

<script src="https://www.yelp.com/embed/widgets.js" async></script>
