---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout
  title="Page Not Found | SoCal Web Experts"
  description="The page you are looking for could not be found. Return home or contact SoCal Web Experts."
  noindex={true}
>
  <section class="py-32 md:py-40">
    <div class="mx-auto w-full max-w-[800px] px-6 text-center">
      <p class="type-eyebrow mb-6">404</p>
      <h1 class="text-[var(--text)] mb-6">Page not found</h1>
      <p class="type-lead mb-10">
        That URL does not exist. Try the homepage or get in touch and we will help you find what you need.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <Button href="/" size="lg">Go home</Button>
        <Button href="/contact/" variant="secondary" size="lg">Contact us</Button>
      </div>
    </div>
  </section>
</BaseLayout>
