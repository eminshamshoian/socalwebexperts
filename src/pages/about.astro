---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
---

<BaseLayout
  title="About SoCal Web Experts | Built for Local Business Growth"
  description="We build fast, secure, lead-generating websites for local businesses - done-for-you, with ongoing support and updates."
>
  <section class="py-24 md:py-32">
    <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16">
      <!-- Header -->
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 mb-16 md:mb-24">
        <div class="fade-in">
          <p class="type-eyebrow mb-6">
            About
          </p>
          <h1 class="text-[var(--text)]">
            Websites should <span class="font-serif italic font-normal">pay for themselves</span>
          </h1>
        </div>
        <div class="flex items-end fade-in" style="animation-delay: 0.1s;">
          <p class="type-lead max-w-lg">
            We started SoCal Web Experts for one reason: too many businesses have websites that look "okay" but do not bring customers.
          </p>
        </div>
      </div>

      <!-- Mission -->
      <div class="grid lg:grid-cols-[1fr_2fr] gap-8 lg:gap-16 mb-16 md:mb-24 fade-in" style="animation-delay: 0.15s;">
        <div>
          <h2 class="type-subheading">
            Our <span class="font-serif italic font-normal underline">mission</span>
          </h2>
        </div>
        <div>
          <p class="type-lead max-w-2xl">
            Build websites that earn trust fast, rank better over time, and turn visitors into leads without you lifting a finger.
          </p>
        </div>
      </div>

      <!-- What makes us different -->
      <div class="mb-16 md:mb-24 fade-in" style="animation-delay: 0.2s;">
        <h2 class="type-subheading pb-10">
          What makes us <span class="font-serif italic font-normal">different</span>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {[
            'Built to convert, not just design',
            'Performance-first builds',
            'SEO-friendly structure from day one',
            'Done-for-you updates and support',
            'Built for competitive service markets',
          ].map((item) => (
            <div class="flex items-start gap-3 p-5 border border-[var(--border)] rounded-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-primary-500 mt-2 shrink-0"></span>
              <span class="text-base leading-relaxed text-[var(--text)]">
                {item}
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA block -->
      <div class="fade-in" style="animation-delay: 0.25s;">
        <p class="type-emphasis pb-8 max-w-2xl">
          If your website is not bringing leads, it is not <span class="font-serif italic font-normal">doing its job.</span>
        </p>
        <Button href="/contact" size="lg">
          Let's Fix That
          <Icon name="arrow-right" size={16} />
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
