---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/ui/Icon.astro';
import Button from '../components/ui/Button.astro';
import { siteConfig, services } from '../data/site';
---

<BaseLayout
  title="Contact Us | SoCal Web Experts"
  description="Get in touch for a free consultation. Let's discuss how we can help grow your business online."
>
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Left - Info -->
        <div class="lg:col-span-2">
          <p class="text-primary-500 text-sm font-medium tracking-wide uppercase mb-3 fade-in">
            Contact
          </p>
          <h1 class="text-3xl md:text-4xl font-bold text-[var(--text)] mb-4 fade-in" style="animation-delay: 0.05s;">
            Let's talk about your project
          </h1>
          <p class="text-[var(--text-secondary)] mb-10 fade-in" style="animation-delay: 0.1s;">
            Schedule a free consultation. No pressure — just a conversation about your goals.
          </p>

          <!-- Contact Methods -->
          <div class="space-y-4 mb-10">
            <a
              href={`tel:${siteConfig.phone.replace(/[^0-9]/g, '')}`}
              class="flex items-center gap-3 p-4 bg-[var(--bg-secondary)] border border-[var(--border)] rounded-xl hover:border-[var(--text-secondary)]/30 transition-colors fade-in"
              style="animation-delay: 0.15s;"
            >
              <div class="w-10 h-10 rounded-lg bg-primary-500/10 flex items-center justify-center">
                <Icon name="phone" size={18} class="text-primary-500" />
              </div>
              <div>
                <div class="text-xs text-[var(--text-secondary)] mb-0.5">Call us</div>
                <div class="font-medium text-[var(--text)]">{siteConfig.phone}</div>
              </div>
            </a>

            <a
              href={`mailto:${siteConfig.email}`}
              class="flex items-center gap-3 p-4 bg-[var(--bg-secondary)] border border-[var(--border)] rounded-xl hover:border-[var(--text-secondary)]/30 transition-colors fade-in"
              style="animation-delay: 0.2s;"
            >
              <div class="w-10 h-10 rounded-lg bg-primary-500/10 flex items-center justify-center">
                <Icon name="mail" size={18} class="text-primary-500" />
              </div>
              <div>
                <div class="text-xs text-[var(--text-secondary)] mb-0.5">Email us</div>
                <div class="font-medium text-[var(--text)]">{siteConfig.email}</div>
              </div>
            </a>
          </div>

          <!-- Response time -->
          <p class="text-sm text-[var(--text-secondary)] fade-in" style="animation-delay: 0.25s;">
            We typically respond within 24 hours.
          </p>
        </div>

        <!-- Right - Form -->
        <div class="lg:col-span-3 fade-in" style="animation-delay: 0.15s;">
          <div class="bg-[var(--bg-secondary)] border border-[var(--border)] rounded-xl p-6 md:p-8">
            <form id="contact-form" class="space-y-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-[var(--text)] mb-2">
                    Name
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-2.5 bg-[var(--bg)] border border-[var(--border)] rounded-lg text-[var(--text)] placeholder-[var(--text-secondary)]/50 focus:border-primary-500 focus:ring-1 focus:ring-primary-500 transition-colors outline-none text-sm"
                    placeholder="John Smith"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-[var(--text)] mb-2">
                    Email
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-2.5 bg-[var(--bg)] border border-[var(--border)] rounded-lg text-[var(--text)] placeholder-[var(--text-secondary)]/50 focus:border-primary-500 focus:ring-1 focus:ring-primary-500 transition-colors outline-none text-sm"
                    placeholder="john@company.com"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="phone" class="block text-sm font-medium text-[var(--text)] mb-2">
                    Phone <span class="text-[var(--text-secondary)] font-normal">(optional)</span>
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full px-4 py-2.5 bg-[var(--bg)] border border-[var(--border)] rounded-lg text-[var(--text)] placeholder-[var(--text-secondary)]/50 focus:border-primary-500 focus:ring-1 focus:ring-primary-500 transition-colors outline-none text-sm"
                    placeholder="(555) 123-4567"
                  />
                </div>
                <div>
                  <label for="service" class="block text-sm font-medium text-[var(--text)] mb-2">
                    Service
                  </label>
                  <select
                    id="service"
                    name="service"
                    class="w-full px-4 py-2.5 bg-[var(--bg)] border border-[var(--border)] rounded-lg text-[var(--text)] focus:border-primary-500 focus:ring-1 focus:ring-primary-500 transition-colors outline-none appearance-none text-sm"
                  >
                    <option value="">Select a service...</option>
                    {services.map((service) => (
                      <option value={service.id}>{service.title}</option>
                    ))}
                    <option value="other">Not sure yet</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-[var(--text)] mb-2">
                  How can we help?
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="w-full px-4 py-2.5 bg-[var(--bg)] border border-[var(--border)] rounded-lg text-[var(--text)] placeholder-[var(--text-secondary)]/50 focus:border-primary-500 focus:ring-1 focus:ring-primary-500 transition-colors outline-none resize-none text-sm"
                  placeholder="Tell us about your project..."
                ></textarea>
              </div>

              <Button type="submit" fullWidth>
                Send message
              </Button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Thanks! We\'ll get back to you within 24 hours.');
    form.reset();
  });
</script>
