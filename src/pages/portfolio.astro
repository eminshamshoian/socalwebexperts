---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollableProjectImage from '../components/ui/ScrollableProjectImage.astro';
import Button from '../components/ui/Button.astro';
import { portfolioItems } from '../data/site';
---

<BaseLayout
  title="Our Work | High-Converting Websites by SoCal Web Experts"
  description="See real examples of fast, modern websites built to convert leads for local service businesses."
>
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-16 md:mb-20">
        <p class="text-primary-500 text-sm font-medium tracking-widest uppercase mb-6 fade-in">
          Portfolio
        </p>
        <h1 class="text-[var(--text)] mb-6 fade-in" style="animation-delay: 0.05s;">
          Work built for<br class="hidden sm:block" />
          <span class="gradient-text">leads and trust</span>
        </h1>
        <p class="text-lg text-[var(--text-secondary)] max-w-xl mx-auto leading-relaxed fade-in" style="animation-delay: 0.1s;">
          Modern design, clear messaging, and fast performance so customers choose you.
        </p>
      </div>

      <!-- Grid -->
      <div class="portfolio-page-grid">
        {portfolioItems.map((item, index) => (
          <div
            class="group fade-in"
            style={`animation-delay: ${index * 0.06}s`}
          >
            <div class="relative h-full rounded-2xl border border-[var(--border)] overflow-hidden transition-all duration-500 hover:border-primary-500/30 hover:shadow-[0_20px_80px_-20px_rgba(249,115,22,0.15)]">
              <!-- Screenshot -->
              <div class="relative overflow-hidden" style="aspect-ratio: 16/10;">
                <ScrollableProjectImage src={item.image} alt={`${item.title} - ${item.categoryLabel} website`} />

                <!-- Hover overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10 flex flex-col justify-end p-6 md:p-8 pointer-events-none">
                  <div class="translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                    <span class="inline-block px-3 py-1 rounded-full bg-primary-500/20 text-primary-400 text-xs font-medium mb-3 backdrop-blur-sm border border-primary-500/20">
                      {item.categoryLabel}
                    </span>
                    <h3 class="text-white text-xl md:text-2xl font-semibold tracking-tight">{item.title}</h3>
                  </div>
                </div>
              </div>

              <!-- Footer -->
              <div class="px-5 py-4 flex items-center justify-between bg-[var(--bg)]">
                <div>
                  <h3 class="text-sm font-semibold text-[var(--text)]">{item.title}</h3>
                  <p class="text-xs text-[var(--text-secondary)] mt-0.5">{item.categoryLabel}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="flex justify-center mt-14 fade-in" style="animation-delay: 0.4s;">
        <Button href="/contact" size="lg">
          Want one like this? Get a Quote
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .portfolio-page-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
</style>
