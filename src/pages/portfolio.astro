---
import BaseLayout from '../layouts/BaseLayout.astro';
import { portfolioItems } from '../data/site';
---

<BaseLayout
  title="Portfolio | SoCal Web Experts"
  description="See our portfolio of web design, SEO, and digital marketing projects for local businesses."
>
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="max-w-2xl mb-10 fade-in">
        <p class="text-primary-500 text-sm font-medium tracking-wide uppercase mb-3">
          Portfolio
        </p>
        <h1 class="text-3xl md:text-4xl font-bold text-[var(--text)] mb-4">
          Our work
        </h1>
        <p class="text-[var(--text-secondary)] text-lg">
          Real projects with real results for local businesses.
        </p>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {portfolioItems.map((item, index) => (
          <div
            class="group fade-in"
            style={`animation-delay: ${index * 0.05}s`}
          >
            <div class="rounded-xl border border-[var(--border)] overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-primary-500/40 hover:shadow-lg hover:shadow-black/10">
              <!-- Image -->
              <div class="aspect-[16/10] overflow-hidden bg-[var(--bg-tertiary)] flex items-center justify-center">
                <img
                  src={item.image}
                  alt={item.title}
                  class="w-full h-full object-contain group-hover:scale-[1.03] transition-transform duration-500"
                  loading="lazy"
                />
              </div>

              <!-- Info -->
              <div class="px-4 py-3 bg-[var(--bg-secondary)]">
                <h3 class="text-sm font-medium text-[var(--text)]">{item.title}</h3>
                <p class="text-xs text-[var(--text-secondary)] mt-0.5">{item.categoryLabel}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
