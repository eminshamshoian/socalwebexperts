---
import BaseLayout from '../layouts/BaseLayout.astro';
import { portfolioItems } from '../data/site';
---

<BaseLayout
  title="Portfolio | SoCal Web Experts"
  description="See our portfolio of web design, SEO, and digital marketing projects for local businesses."
>
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="max-w-2xl mb-10 fade-in">
        <p class="text-primary-500 text-sm font-medium tracking-wide uppercase mb-3">
          Portfolio
        </p>
        <h1 class="text-3xl md:text-4xl font-bold text-[var(--text)] mb-4">
          Our work
        </h1>
        <p class="text-[var(--text-secondary)] text-lg">
          Real projects with real results for local businesses.
        </p>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {portfolioItems.map((item, index) => (
          <div
            class="group fade-in"
            style={`animation-delay: ${index * 0.05}s`}
          >
            <div class="rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1">
              <!-- Mockup Image -->
              <div class="aspect-[4/3] relative bg-gradient-to-br from-slate-100 via-blue-50 to-slate-100 dark:from-slate-800 dark:via-slate-900 dark:to-slate-800 rounded-2xl overflow-hidden flex items-center justify-center p-6">
                <img
                  src={item.image}
                  alt={item.title}
                  class="w-full h-full object-contain drop-shadow-2xl group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>

              <!-- Category Label -->
              <div class="pt-4 text-center">
                <span class="text-sm font-medium tracking-wide uppercase text-[var(--text-secondary)]">
                  {item.categoryLabel}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
