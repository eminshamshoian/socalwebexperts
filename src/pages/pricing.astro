---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/ui/Icon.astro';
import Button from '../components/ui/Button.astro';
import FAQ from '../components/sections/FAQ.astro';
import { pricingModels } from '../data/site';

const addOns = [
  { title: 'Google Ads', price: 'from $500/mo', desc: 'Campaign setup, optimization, and tracking' },
  { title: 'Social Media', price: 'from $400/mo', desc: 'Content creation and posting schedule' },
  { title: 'Ecommerce', price: 'from $2,500', desc: 'Shopify setup with payment and shipping' },
];
---

<BaseLayout
  title="Web Design Pricing | $0 Down Monthly or Ownership | SoCal Web Experts"
  description="Choose $0 down monthly with hosting + ongoing updates, or an ownership build with low monthly hosting. Built for speed, security, and lead generation."
>
  <section class="py-24 md:py-32">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-16 md:mb-24 fade-in">
        <p class="text-primary-500 text-sm font-medium tracking-widest uppercase mb-6">
          Pricing
        </p>
        <h1 class="text-[var(--text)] text-center mb-6">
          Simple pricing. Built for growth.
        </h1>
        <p class="text-lg md:text-xl text-[var(--text-secondary)] text-center leading-relaxed">
          Pick the option that fits your business - both are designed to help you win more customers.
        </p>
      </div>

      <!-- Pricing Cards -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8 max-w-5xl mx-auto mb-16 md:mb-24">
        {pricingModels.map((plan, index) => (
          <div 
            class={`relative p-8 md:p-10 bg-[var(--bg-secondary)] border rounded-2xl fade-in ${plan.highlighted ? 'border-primary-500' : 'border-[var(--border)]'}`}
            style={`animation-delay: ${index * 0.1}s`}
          >
            {plan.highlighted && (
              <div class="absolute -top-4 left-8 px-5 py-1.5 bg-primary-500 text-white text-xs font-semibold rounded-full tracking-wide">
                Most Popular
              </div>
            )}

            <h3 class="text-xl font-semibold text-[var(--text)] mb-2">{plan.title}</h3>
            <p class="text-[var(--text-secondary)] mb-8">{plan.subtitle}</p>

            <div class="mb-8 py-8 border-b border-[var(--border)]">
              <div class="flex items-baseline gap-2">
                <span class="text-5xl md:text-6xl font-bold text-[var(--text)] tracking-tight">{plan.upfront}</span>
                {plan.upfront !== '$0' && <span class="text-lg text-[var(--text-secondary)]">Total</span>}
              </div>
              <p class="text-[var(--text-secondary)] mt-2">+ {plan.monthly}/mo hosting</p>
            </div>

            <ul class="space-y-4 mb-10">
              {plan.features.slice(0, 8).map((feature) => (
                <li class="flex items-start gap-3">
                  <div class="w-5 h-5 rounded-full bg-primary-500/15 flex items-center justify-center shrink-0 mt-0.5">
                    <Icon name="check" size={12} class="text-primary-500" />
                  </div>
                  <span class="text-[var(--text)]">{feature}</span>
                </li>
              ))}
            </ul>

            <Button href="/contact" variant={plan.highlighted ? 'primary' : 'secondary'} fullWidth size="lg">
              {plan.id === 'growth' ? 'Start the Growth Plan' : 'Get the Ownership Build'}
            </Button>
          </div>
        ))}
      </div>

      <!-- Add-ons -->
      <div class="max-w-5xl mx-auto mb-16 md:mb-24">
        <h2 class="text-[var(--text)] pb-6 fade-in">Optional add-ons</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {addOns.map((addon, index) => (
            <div 
              class="flex items-start justify-between gap-4 p-6 bg-[var(--bg-secondary)] border border-[var(--border)] rounded-2xl fade-in"
              style={`animation-delay: ${0.2 + index * 0.05}s`}
            >
              <div>
                <h3 class="font-medium text-[var(--text)] mb-2">{addon.title}</h3>
                <p class="text-sm text-[var(--text-secondary)]">{addon.desc}</p>
              </div>
              <span class="text-sm font-medium text-primary-500 whitespace-nowrap">{addon.price}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <FAQ />
</BaseLayout>
