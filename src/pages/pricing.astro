---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/ui/Icon.astro';
import Button from '../components/ui/Button.astro';
import FAQ from '../components/sections/FAQ.astro';
import { pricingModels } from '../data/site';

const addOns = [
  { title: 'Google Ads', price: 'from $500/mo', desc: 'Campaign setup, optimization, and tracking' },
  { title: 'Social Media', price: 'from $400/mo', desc: 'Content creation and posting schedule' },
  { title: 'Ecommerce', price: 'from $2,500', desc: 'Shopify setup with payment and shipping' },
];
---

<BaseLayout
  title="Website Pricing | From $299 Setup + $12/mo Hosting | SoCal Web Experts"
  description="Custom website starting from $299 setup fee, $12/mo or $99/yr hosting. After your design is approved, updates are $100/hour."
>
  <section class="py-24 md:py-32">
    <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 mb-16 md:mb-24">
        <div class="fade-in">
          <p class="type-eyebrow mb-6">
            Pricing
          </p>
          <h1 class="text-[var(--text)]">
            Simple pricing. Built for growth.
          </h1>
        </div>
        <div class="flex items-end fade-in" style="animation-delay: 0.1s;">
          <p class="type-lead max-w-lg">
            Starting from $299 setup, affordable hosting, and hourly updates only after you are happy with the design.
          </p>
        </div>
      </div>

      <div class="w-full space-y-6 mb-24 md:mb-32">
        {pricingModels.map((plan, index) => (
          <div
            class={`rounded-lg overflow-hidden fade-in ${plan.highlighted ? 'bg-primary-400' : 'border border-[var(--border)]'}`}
            style={`animation-delay: ${index * 0.1}s`}
          >
            <div class="grid grid-cols-1 md:grid-cols-2">
              <div class="p-8 md:p-10 lg:p-14 xl:p-16">
                <p
                  class={`text-xs uppercase tracking-[0.2em] mb-2 ${plan.highlighted ? 'text-black' : 'text-[var(--text-secondary)]'}`}
                >
                  {plan.subtitle}
                </p>
                <h2
                  class={`text-base font-medium pb-6 ${plan.highlighted ? 'text-black' : 'text-[var(--text)]'}`}
                >
                  {plan.title}
                </h2>
                {plan.upfrontPrefix && (
                  <p class={`text-sm pb-1 ${plan.highlighted ? 'text-black' : 'text-[var(--text-secondary)]'}`}>
                    {plan.upfrontPrefix}
                  </p>
                )}
                <div class="flex items-baseline gap-3 pb-2">
                  <span
                    class={`text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter ${plan.highlighted ? 'text-black' : 'text-[var(--text)]'}`}
                  >
                    {plan.upfront}
                  </span>
                  <span class={`text-base ${plan.highlighted ? 'text-black' : 'text-[var(--text-secondary)]'}`}>
                    {plan.upfrontLabel ?? 'upfront'}
                  </span>
                </div>
                <p class={`text-sm pb-10 ${plan.highlighted ? 'text-black' : 'text-[var(--text-secondary)]'}`}>
                  {plan.yearly
                    ? `${plan.monthly} a month or ${plan.yearly} yearly`
                    : `+ ${plan.monthly}/mo hosting`}
                </p>
                {plan.highlighted ? (
                  <a
                    href="/contact"
                    class="inline-flex items-center justify-center gap-2 font-medium rounded-md px-8 py-3.5 text-base tracking-tight bg-primary-500 text-on-primary shadow-[4px_4px_0px_0px_#A35139] hover:shadow-[2px_2px_0px_0px_#A35139] hover:translate-x-[2px] hover:translate-y-[2px] active:shadow-none active:translate-x-1 active:translate-y-1 transition-all duration-150"
                  >
                    Get started
                    <Icon name="arrow-right" size={16} />
                  </a>
                ) : (
                  <Button href="/contact" variant="primary" size="lg">
                    Get started
                    <Icon name="arrow-right" size={16} />
                  </Button>
                )}
              </div>
              <div
                class={`p-8 md:p-10 lg:p-14 xl:p-16 border-t md:border-t-0 md:border-l ${plan.highlighted ? 'border-primary-500/30' : 'border-[var(--border)]'}`}
              >
                <h3
                  class={`text-sm font-medium pb-8 ${plan.highlighted ? 'text-black' : 'text-[var(--text)]'}`}
                >
                  What's included
                </h3>
                <ul class="space-y-4">
                  {plan.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <Icon
                        name="check"
                        size={16}
                        class={`mt-0.5 shrink-0 ${plan.highlighted ? 'text-black' : 'text-primary-500'}`}
                      />
                      <span class={`text-sm ${plan.highlighted ? 'text-black' : 'text-[var(--text)]'}`}>
                        {feature}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mb-24 md:mb-32">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 pb-12">
          <div class="fade-in">
            <h2 class="text-[var(--text)]">
              Optional add-ons
            </h2>
          </div>
        </div>
        <div class="border-t border-[var(--border)]">
          {addOns.map((addon, index) => (
            <div
              class="flex flex-col md:flex-row md:items-center justify-between gap-4 py-6 md:py-8 border-b border-[var(--border)] fade-in"
              style={`animation-delay: ${0.2 + index * 0.05}s`}
            >
              <div>
                <h3 class="type-card-title pb-1">{addon.title}</h3>
                <p class="type-body-card">{addon.desc}</p>
              </div>
              <span class="type-caption font-medium text-primary-500 whitespace-nowrap">{addon.price}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <FAQ />
</BaseLayout>
