---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/ui/Button.astro';
import CTA from '../../components/sections/CTA.astro';
import { services } from '../../data/site';
import type { GetStaticPaths } from 'astro';
import type { Service } from '../../types';

export const getStaticPaths: GetStaticPaths = async () => {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
};

const { service } = Astro.props as { service: Service };
const relatedServices = services.filter(s => s.id !== service.id).slice(0, 3);

const shapes = [
  `<svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M120 0 A120 120 0 0 1 0 120" stroke="currentColor" stroke-width="0.6"/><path d="M90 0 A90 90 0 0 1 0 90" stroke="currentColor" stroke-width="0.4"/></svg>`,
  `<svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="60" cy="60" r="55" stroke="currentColor" stroke-width="0.6"/><circle cx="60" cy="60" r="30" stroke="currentColor" stroke-width="0.4"/></svg>`,
  `<svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 60 Q30 10, 60 60 T120 60" stroke="currentColor" stroke-width="0.6"/><path d="M0 80 Q30 30, 60 80 T120 80" stroke="currentColor" stroke-width="0.4"/></svg>`,
];
---

<BaseLayout
  title={`${service.title} | SoCal Web Experts`}
  description={service.description}
>
  <section class="py-24 md:py-32">
    <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16">
      <!-- Back link -->
      <a href="/#services" class="type-caption inline-flex items-center gap-1.5 hover:text-[var(--text)] transition-colors mb-12 fade-in">
        <Icon name="chevron-right" size={14} class="rotate-180" />
        Services
      </a>

      <!-- Header -->
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 mb-16 md:mb-24">
        <div class="fade-in" style="animation-delay: 0.05s;">
          <p class="type-eyebrow mb-6">
            {service.title}
          </p>
          <h1 class="text-[var(--text)]">
            {service.title}
          </h1>
        </div>
        <div class="flex items-end fade-in" style="animation-delay: 0.1s;">
          <p class="type-lead max-w-lg">
            {service.description}
          </p>
        </div>
      </div>

      <!-- Features + CTA -->
      <div class="grid lg:grid-cols-[2fr_1fr] gap-12 lg:gap-16">
        <!-- Features as visual blocks -->
        <div class="fade-in" style="animation-delay: 0.15s;">
          <div class="features-grid">
            {service.features.map((feature, index) => (
              <div class="group/f relative overflow-hidden border border-[var(--border)] rounded-sm p-5 md:p-6 transition-all duration-400 hover:border-primary-500/30">
                <div
                  class="absolute -bottom-3 -right-3 w-16 h-16 pointer-events-none feature-shape"
                  aria-hidden="true"
                  set:html={shapes[index % shapes.length]}
                />
                <div class="relative z-10 flex items-start gap-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-primary-500 mt-2 shrink-0"></span>
                  <span class="text-sm md:text-base leading-relaxed text-[var(--text)]">
                    {feature}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Sticky CTA -->
        <div class="fade-in" style="animation-delay: 0.2s;">
          <div class="lg:sticky lg:top-32">
            <p class="type-emphasis pb-6">
              Ready to get started?
            </p>
            <div class="flex flex-col gap-3">
              <Button href="/contact" size="lg">
                Book a Free Strategy Call
                <Icon name="arrow-right" size={16} />
              </Button>
              <Button href="/pricing" variant="secondary" size="lg">
                View Pricing
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="py-16 md:py-24">
    <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16">
      <h2 class="type-subheading mb-10 fade-in">
        Related services
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {relatedServices.map((related, index) => (
          <a
            href={`/services/${related.slug}`}
            class="group relative flex items-start gap-4 p-5 md:p-6 border border-[var(--border)] rounded-sm overflow-hidden transition-all duration-400 hover:border-primary-500/30 fade-in"
            style={`animation-delay: ${index * 0.05}s`}
          >
            <div
              class="absolute -bottom-2 -right-2 w-20 h-20 pointer-events-none related-shape"
              aria-hidden="true"
              set:html={shapes[index % shapes.length]}
            />
            <Icon name={related.icon} size={18} class="text-primary-500 shrink-0 mt-0.5 relative z-10" />
            <div class="relative z-10">
              <h3 class="type-card-title group-hover:text-primary-500 transition-colors">
                {related.title}
              </h3>
              <p class="type-body-card mt-1">
                {related.shortDescription}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>

<style>
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .feature-shape {
    color: rgba(132, 204, 22, 0.04);
    transition: color 0.5s ease, transform 0.5s ease;
  }

  .group\/f:hover .feature-shape {
    color: rgba(132, 204, 22, 0.1);
    transform: rotate(10deg) scale(1.15);
  }

  .related-shape {
    color: rgba(132, 204, 22, 0.04);
    transition: color 0.5s ease, transform 0.5s ease;
  }

  .group:hover .related-shape {
    color: rgba(132, 204, 22, 0.08);
    transform: rotate(10deg);
  }
</style>
