---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/ui/Button.astro';
import CTA from '../../components/sections/CTA.astro';
import { services } from '../../data/site';
import type { GetStaticPaths } from 'astro';
import type { Service } from '../../types';

export const getStaticPaths: GetStaticPaths = async () => {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
};

const { service } = Astro.props as { service: Service };
const relatedServices = services.filter((item) => item.id !== service.id);
const layoutClass = `service-page service-page--${service.layout}`;
---

<BaseLayout
  title={`${service.title} | SoCal Web Experts`}
  description={service.description}
>
  <section class={`${layoutClass} py-20 md:py-28`}>
    <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16">
      <!-- Hero -->
      <header class={`service-hero fade-in service-hero--${service.layout}`}>
        <div class="service-hero__copy">
          <p class="type-eyebrow mb-6">{service.title}</p>
          <h1 class="text-[var(--text)] max-w-4xl">{service.heroHeadline}</h1>
          <p class="type-lead mt-6 max-w-2xl">{service.description}</p>
          <div class="flex flex-wrap gap-3 mt-8">
            <Button href="/contact" size="lg">
              Book a Free Strategy Call
              <Icon name="arrow-right" size={16} />
            </Button>
            <Button href="/pricing" variant="secondary" size="lg">
              View Pricing
            </Button>
          </div>
        </div>
        {service.layout === 'split' && (
          <div class="service-hero__media fade-in" style="animation-delay: 0.08s;">
            <img
              src={service.highlights[0]?.image}
              alt={service.highlights[0]?.imageAlt || service.title}
              class="service-hero__image"
              loading="eager"
            />
          </div>
        )}
      </header>

      <!-- Highlight row -->
      <div class={`service-highlights service-highlights--${service.layout} mt-16 md:mt-24`}>
        {service.highlights.map((item, index) => (
          <article
            class="service-highlight fade-in"
            style={`animation-delay: ${0.08 + index * 0.05}s`}
          >
            {service.layout === 'media-first' ? (
              <>
                <div class="service-highlight__media">
                  <img src={item.image} alt={item.imageAlt} loading="lazy" />
                </div>
                <h2 class="service-highlight__title">{item.title}</h2>
                <p class="service-highlight__desc">{item.description}</p>
              </>
            ) : (
              <>
                <h2 class="service-highlight__title">{item.title}</h2>
                <div class="service-highlight__media">
                  <img src={item.image} alt={item.imageAlt} loading="lazy" />
                </div>
                <p class="service-highlight__desc">{item.description}</p>
              </>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Details / services grid -->
  <section class="pb-20 md:pb-28">
    <div class="mx-auto w-full max-w-[1400px] px-6 lg:px-16">
      <div class={`service-details-head service-details-head--${service.layout} fade-in mb-10 md:mb-14`}>
        <p class="type-eyebrow mb-4">Services</p>
        <h2 class="text-[var(--text)] max-w-3xl">
          {service.layout === 'classic' && 'Everything you need to launch a site that brings customers.'}
          {service.layout === 'media-first' && 'A practical social system that keeps your brand present.'}
          {service.layout === 'split' && 'Paid search built around leads, not vanity metrics.'}
        </h2>
      </div>

      <div class={`service-details-grid service-details-grid--${service.layout}`}>
        {service.details.map((detail, index) => (
          <article
            class="service-detail fade-in"
            style={`animation-delay: ${0.08 + index * 0.04}s`}
          >
            <div class="service-detail__icon" aria-hidden="true">
              <Icon name={detail.icon} size={18} />
            </div>
            <h3 class="service-detail__title">{detail.title}</h3>
            <p class="service-detail__desc">{detail.description}</p>
          </article>
        ))}
      </div>

      <!-- Related -->
      {relatedServices.length > 0 && (
        <div class="mt-16 md:mt-24 fade-in">
          <h2 class="type-subheading mb-8">Explore related services</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {relatedServices.map((related) => (
              <a
                href={`/services/${related.slug}`}
                class="group flex items-start gap-4 border border-[var(--border)] rounded-xl p-5 md:p-6 bg-[var(--bg-secondary)] transition-colors hover:border-primary-500/35"
              >
                <span class="service-detail__icon shrink-0" aria-hidden="true">
                  <Icon name={related.icon} size={18} />
                </span>
                <span>
                  <span class="block type-card-title group-hover:text-primary-500 transition-colors">{related.title}</span>
                  <span class="block type-body-card mt-2">{related.shortDescription}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <CTA />
</BaseLayout>

<style>
  .service-hero {
    display: grid;
    gap: 2rem;
  }

  .service-hero--split {
    align-items: end;
  }

  @media (min-width: 1024px) {
    .service-hero--split {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 3rem;
    }
  }

  .service-hero__image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border: 1px solid var(--border);
    border-radius: 1rem;
  }

  .service-hero--classic .service-hero__copy,
  .service-hero--media-first .service-hero__copy {
    max-width: 52rem;
  }

  .service-highlights {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem 1.25rem;
  }

  @media (min-width: 640px) {
    .service-highlights {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .service-highlights--classic,
    .service-highlights--media-first {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }

    .service-highlights--split {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  .service-highlight {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .service-highlights--media-first .service-highlight {
    gap: 0.85rem;
  }

  .service-highlight__title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .service-highlight__media {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 1rem;
    aspect-ratio: 1 / 1.05;
  }

  .service-highlights--split .service-highlight__media {
    aspect-ratio: 16 / 10;
  }

  .service-highlight__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .service-highlight__desc {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .service-details-head--media-first {
    text-align: left;
  }

  .service-details-head--split {
    max-width: 40rem;
  }

  .service-details-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }

  @media (min-width: 768px) {
    .service-details-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .service-details-grid--classic,
    .service-details-grid--media-first {
      grid-template-columns: repeat(3, 1fr);
    }

    .service-details-grid--split {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .service-detail {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-height: 100%;
    padding: 1.35rem 1.25rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: var(--bg-secondary);
  }

  .service-details-grid--media-first .service-detail {
    padding-top: 1.5rem;
  }

  .service-details-grid--split .service-detail {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 1rem 1.1rem;
  }

  .service-details-grid--split .service-detail__title,
  .service-details-grid--split .service-detail__desc {
    width: calc(100% - 3rem);
    margin-left: auto;
  }

  .service-detail__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 9999px;
    background: var(--color-primary-500);
    color: var(--color-on-primary, #1B2632);
  }

  .service-detail__title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .service-detail__desc {
    margin: 0;
    flex: 1;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }
</style>
