---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import CTA from '../../components/sections/CTA.astro';
import { services } from '../../data/site';
---

<BaseLayout
  title="Services | SoCal Web Experts"
  description="Web design, SEO, Google Ads, social media marketing, and ecommerce solutions for local businesses."
>
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="max-w-2xl mb-14 fade-in">
        <p class="text-primary-500 text-sm font-medium tracking-wide uppercase mb-3">
          Services
        </p>
        <h1 class="text-3xl md:text-4xl font-bold text-[var(--text)] mb-4">
          Everything you need to grow online
        </h1>
        <p class="text-[var(--text-secondary)] text-lg">
          From website design to digital marketing, we handle it all.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((service, index) => (
          <a 
            href={`/services/${service.slug}`} 
            class="group block p-6 bg-[var(--bg-secondary)] border border-[var(--border)] rounded-xl hover:border-[var(--text-secondary)]/30 transition-colors fade-in"
            style={`animation-delay: ${index * 0.05}s`}
          >
            <div class="flex items-start justify-between mb-4">
              <div class="w-10 h-10 rounded-lg bg-primary-500/10 flex items-center justify-center">
                <Icon name={service.icon} size={20} class="text-primary-500" />
              </div>
              <Icon name="arrow-right" size={16} class="text-[var(--text-secondary)] opacity-0 group-hover:opacity-100 transition-opacity" />
            </div>
            
            <h2 class="text-lg font-semibold text-[var(--text)] mb-2 group-hover:text-primary-500 transition-colors">
              {service.title}
            </h2>
            <p class="text-sm text-[var(--text-secondary)] mb-4">
              {service.shortDescription}
            </p>
            
            <ul class="space-y-1.5">
              {service.features.slice(0, 3).map((feature) => (
                <li class="flex items-center gap-2 text-xs text-[var(--text-secondary)]">
                  <Icon name="check" size={12} class="text-primary-500" />
                  {feature}
                </li>
              ))}
            </ul>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
