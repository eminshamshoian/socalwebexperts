---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/ui/Button.astro';
import { services } from '../../data/site';
---

<BaseLayout
  title="Web Design, SEO & Website Management | SoCal Web Experts"
  description="Custom websites built for speed, trust, and Google visibility. Hosting included. Ongoing updates available. Built to generate leads for local businesses."
>
  <section class="py-24 md:py-32">
    <div class="container">
      <div class="max-w-3xl my-16 md:my-24 fade-in">
        <p class="text-primary-500 text-sm font-medium tracking-widest uppercase my-6">
          Services
        </p>
        <h1 class="text-[var(--text)] my-6">
          Services built around one outcome: more customers
        </h1>
        <p class="text-lg md:text-xl text-[var(--text-secondary)] leading-relaxed">
          Speed, trust, and SEO structure so you get more calls and inquiries.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service, index) => (
          <a 
            href={`/services/${service.slug}`} 
            class="group block p-8 bg-[var(--bg-secondary)] border border-[var(--border)] rounded-2xl hover:border-[var(--text-secondary)]/30 transition-colors fade-in"
            style={`animation-delay: ${index * 0.05}s`}
          >
            <div class="flex items-start justify-between my-6">
              <div class="w-12 h-12 rounded-2xl bg-primary-500/10 flex items-center justify-center">
                <Icon name={service.icon} size={22} class="text-primary-500" />
              </div>
              <Icon name="arrow-right" size={16} class="text-[var(--text-secondary)] opacity-0 group-hover:opacity-100 transition-opacity" />
            </div>
            
            <h2 class="text-lg font-semibold text-[var(--text)] my-3 group-hover:text-primary-500 transition-colors">
              {service.title}
            </h2>
            <p class="text-[var(--text-secondary)] my-6 leading-relaxed">
              {service.shortDescription}
            </p>
            
            <ul class="space-y-2">
              {service.features.slice(0, 3).map((feature) => (
                <li class="flex items-center gap-2 text-sm text-[var(--text-secondary)]">
                  <Icon name="check" size={14} class="text-primary-500" />
                  {feature}
                </li>
              ))}
            </ul>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32">
    <div class="container">
      <div class="max-w-3xl p-8 md:p-10 rounded-2xl border border-[var(--border)] bg-[var(--bg-secondary)]">
        <h2 class="text-[var(--text)] my-6">Not sure what you need?</h2>
        <p class="text-lg text-[var(--text-secondary)] leading-relaxed my-6">We will recommend the simplest path to more leads.</p>
        <Button href="/contact" size="md">
          Book a Free Strategy Call
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
